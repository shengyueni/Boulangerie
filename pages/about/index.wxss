.about-head {
  margin-bottom: 22rpx;
}

.body-text {
  display: block;
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.75;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: 18rpx 0 4rpx;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.6;
}

.theme-toolbox .about-head,
.theme-toolbox .feedback-card {
  border-color: var(--page-theme-soft);
}

.danger-card {
  border-color: rgba(184, 74, 58, 0.56);
  background: #fff8f3;
}
