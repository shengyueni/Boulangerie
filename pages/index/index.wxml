<view class="page paper-page today-page">
  <view class="page-head home-brand-head">
    <text class="hero-title">{{appMeta.appName}}</text>
    <text class="subtext">{{appMeta.slogan}}</text>
  </view>

  <view class="oracle-card paper-title title-pattern-card"><image class="title-pattern-image" src="/assets/tabbar-source/warm-orange.png" mode="aspectFill" /><view class="title-pattern-mask"></view>
    <view class="corner-ornament corner-ornament-left corner-ornament--blue"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <view class="corner-ornament corner-ornament-bottom-left corner-ornament--purple"></view>
    <view class="corner-ornament corner-ornament-bottom-right corner-ornament--red"></view>
    <view class="oracle-sky">
      <view class="oracle-ring"></view>
      <view class="oracle-star star-a"></view>
      <view class="oracle-star star-b"></view>
      <view class="oracle-star star-c"></view>
    </view>
    <text class="paper-title__stamp">{{oracle.dateLabel}}</text>
    <text class="oracle-title">今日职场猩象</text>
    <text class="oracle-subtitle">不预测命运，只看今天的职场天气</text>
    <view class="paper-title__rail">
      <view class="paper-title__rail-line"></view>
      <view class="paper-title__rail-dot"></view>
      <view class="paper-title__rail-dot"></view>
      <view class="paper-title__rail-line"></view>
    </view>

    <view class="oracle-metrics">
      <view wx:for="{{oracle.metrics}}" wx:key="name" class="oracle-metric">
        <text class="metric-name">{{item.name}}：{{item.value}}</text>
        <text class="metric-desc">{{item.description}}</text>
      </view>
    </view>

    <view class="oracle-slip-row">
      <view class="oracle-slip amulet-note">
        <text class="slip-label">今日护身符</text>
        <text class="slip-text">{{oracle.talisman}}</text>
      </view>
      <view class="oracle-slip amulet-note">
        <text class="slip-label">推荐行动</text>
        <text class="slip-text">{{oracle.action}}</text>
      </view>
    </view>

    <text class="oracle-disclaimer">本卡不预测命运，只帮你识别今天的职场天气。</text>
  </view>

  <view class="amulet-card amulet-frame status-card {{croissant.statusClass}} today-status-card">
    <view class="corner-ornament corner-ornament-left corner-ornament--gold"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--green"></view>
    <view class="today-status-layout">
      <view class="today-status-copy">
        <text class="amulet-frame__seal">Croissant 今日状态</text>
        <view class="row between status-headline">
          <text class="status-name today-status-name">{{croissant.status}}</text>
          <text class="status-wear">磨损值：{{croissant.wear}}</text>
        </view>
        <text class="body-text compact-status-text">{{croissant.explanation}}</text>
        <text class="today-companion-line">{{todayStatus.message}}</text>
      </view>
      <view class="today-status-figure" bindtap="goDashboard">
        <image class="today-status-image" src="{{todayStatus.image}}" mode="aspectFit" />
        <text class="today-status-hint">点点 Croissant 看仪表盘</text>
      </view>
    </view>
    <view class="today-status-bottom">
      <text class="today-advice-text">{{todayStatus.advice}}</text>
      <view class="quick-pills">
        <button class="quick-pill" bindtap="recordToday">写日记</button>
        <button class="quick-pill" bindtap="goEmergency">急救一下</button>
        <button class="quick-pill" bindtap="goPlan">查看计划</button>
      </view>
    </view>
  </view>

  <text class="version-note">当前版本：{{appMeta.version}} {{appMeta.stage}}</text>
</view>
