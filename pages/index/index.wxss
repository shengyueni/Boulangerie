.kingdom-head {
  margin-bottom: 12rpx;
}

.kingdom-status {
  margin-top: 18rpx;
}

.protect-note {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 2rpx dashed rgba(74, 57, 47, 0.45);
  border-radius: 20rpx;
  background: rgba(255, 253, 246, 0.62);
  font-size: 27rpx;
  line-height: 1.6;
  font-weight: 800;
}

.welcome-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border: 3rpx solid rgba(74, 57, 47, 0.7);
  border-radius: 26rpx;
  background: #fff2c4;
  box-shadow: 6rpx 6rpx 0 rgba(63, 52, 45, 0.12);
  font-size: 29rpx;
  line-height: 1.55;
  font-weight: 800;
}

.map-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.map-card {
  min-height: 178rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 26rpx;
  background: var(--paper);
  box-shadow: 6rpx 6rpx 0 rgba(63, 52, 45, 0.13);
  transform: rotate(-0.4deg);
}

.map-card:nth-child(2n) {
  transform: rotate(0.5deg);
}

.map-card.large,
.map-card.wide {
  grid-column: span 2;
}

.map-card.pink {
  background: #f8c9d2;
}

.map-card.green {
  background: #d9efc8;
}

.map-card.yellow {
  background: #ffe8a8;
}

.map-card.paper {
  background: #fffdf6;
}

.map-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 31rpx;
  line-height: 1.25;
  font-weight: 900;
}

.map-subtitle {
  display: block;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 700;
}
