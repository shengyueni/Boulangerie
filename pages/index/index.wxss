.today-page { background: linear-gradient(180deg, #fffefb 0%, #fff9ef 100%); }
.home-brand-head { margin-bottom: 16rpx; padding-bottom: 4rpx; text-align: center; }
.home-brand-head .hero-title { margin-bottom: 6rpx; }

.oracle-card {
  margin-top: 8rpx;
  padding: 42rpx 30rpx 32rpx;
  overflow: hidden;
  text-align: center;
}

.oracle-sky {
  position: absolute;
  top: 22rpx;
  right: 26rpx;
  width: 150rpx;
  height: 150rpx;
  opacity: .34;
  pointer-events: none;
}

.oracle-ring {
  position: absolute;
  left: 18rpx;
  top: 20rpx;
  width: 98rpx;
  height: 98rpx;
  border: 3rpx solid rgba(27, 58, 92, .48);
  border-radius: 50%;
  box-shadow: inset 0 0 0 16rpx rgba(184, 138, 74, .08);
}

.oracle-star {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid rgba(184, 138, 74, .9);
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
  background: #fffefb;
}

.star-a { left: 10rpx; top: 18rpx; }
.star-b { right: 20rpx; top: 42rpx; border-color: rgba(184, 74, 58, .75); }
.star-c { left: 56rpx; bottom: 8rpx; border-color: rgba(47, 107, 79, .75); }

.oracle-title {
  display: block;
  margin-top: 10rpx;
  color: var(--ink);
  font-size: 50rpx;
  line-height: 1.16;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.oracle-subtitle {
  display: block;
  margin-top: 10rpx;
  color: var(--blue);
  font-size: 26rpx;
  font-weight: 900;
}

.oracle-metrics {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  margin-top: 24rpx;
  text-align: left;
}

.oracle-metric {
  position: relative;
  padding: 16rpx 18rpx 16rpx 24rpx;
  border: 2rpx solid rgba(184, 138, 74, .38);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 254, 251, .78);
  box-shadow: 0 8rpx 20rpx rgba(74, 52, 40, .05);
}

.metric-name {
  display: block;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.36;
  font-weight: 900;
}

.metric-desc {
  display: block;
  margin-top: 5rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.oracle-slip-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  margin-top: 20rpx;
  text-align: left;
}

.oracle-slip { min-height: 104rpx; }
.slip-label { display: block; margin-bottom: 8rpx; color: var(--muted); font-size: 22rpx; font-weight: 900; letter-spacing: 1rpx; }
.slip-text { display: block; color: var(--ink); font-size: 27rpx; line-height: 1.56; font-weight: 900; }

.oracle-disclaimer {
  display: block;
  margin-top: 20rpx;
  padding: 14rpx 16rpx;
  border: 2rpx dashed rgba(27, 58, 92, .32);
  border-radius: 18rpx;
  color: var(--muted);
  background: rgba(255, 254, 251, .72);
  font-size: 24rpx;
  line-height: 1.55;
  text-align: left;
}

.today-status-card {
  margin-top: 24rpx;
  padding: 34rpx 24rpx 24rpx;
}

.today-status-layout {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.today-status-copy {
  flex: 1;
  min-width: 0;
}

.status-headline {
  align-items: flex-start;
  gap: 12rpx;
}

.today-status-name {
  flex: 1;
  min-width: 0;
  margin: 8rpx 0 10rpx;
  font-size: 37rpx;
}

.status-wear {
  flex: 0 0 auto;
  margin-top: 8rpx;
  margin-bottom: 0;
  padding: 7rpx 14rpx;
  font-size: 22rpx;
}

.compact-status-text {
  font-size: 26rpx;
  line-height: 1.58;
}

.today-companion-line {
  display: block;
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.55;
  font-weight: 800;
}

.today-status-image {
  flex: 0 0 auto;
  width: 116rpx;
  height: 132rpx;
  background: transparent;
}

.today-status-bottom {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx dashed rgba(184, 138, 74, .34);
}

.today-advice-text {
  display: block;
  color: var(--ink);
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 900;
}

.compact-button { min-height: 72rpx; margin-top: 16rpx; }

.quick-card {
  margin-top: 24rpx;
  padding: 36rpx 22rpx 22rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.quick-entry {
  position: relative;
  min-height: 150rpx;
  padding: 16rpx 12rpx;
  border: 2rpx solid rgba(184, 138, 74, .42);
  border-radius: 18rpx;
  background: #fffefb;
  box-shadow: 0 8rpx 20rpx rgba(74, 52, 40, .05);
}

.quick-entry .paper-seal {
  min-height: 34rpx;
  padding: 3rpx 12rpx;
  font-size: 20rpx;
}

.quick-title {
  display: block;
  margin-top: 12rpx;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 900;
}

.quick-desc {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.42;
}

@media (max-width: 360px) {
  .quick-grid { grid-template-columns: 1fr; }
  .quick-entry { min-height: auto; }
  .today-status-layout { align-items: flex-start; }
  .today-status-image { width: 96rpx; height: 112rpx; }
  .status-headline { flex-direction: column; }
  .status-wear { margin-top: 0; }
}
