.today-page {
  background: linear-gradient(180deg, #fffefb 0%, #fff9ef 100%);
}

.home-brand-head {
  margin-bottom: 10rpx;
  padding: 0 0 2rpx;
  text-align: center;
}

.home-brand-head .hero-title {
  margin-bottom: 4rpx;
  font-size: 44rpx;
}

.home-brand-head .subtext {
  font-size: 25rpx;
  line-height: 1.45;
}

.oracle-card {
  margin-top: 2rpx;
  padding: 34rpx 24rpx 24rpx;
  overflow: hidden;
  text-align: center;
}

.oracle-bg,
.oracle-bg-image,
.oracle-sky,
.oracle-card .corner-ornament {
  position: absolute;
  pointer-events: none;
}

.oracle-card .title-pattern-image,
.oracle-bg-image {
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.14;
}

.oracle-bg {
  inset: 0;
  z-index: 1;
  background: rgba(255, 250, 242, 0.66);
}

.oracle-main,
.oracle-title-block,
.oracle-content {
  position: relative;
  z-index: 2;
}

.oracle-title-block {
  display: block;
  margin: 0 auto;
}

.oracle-header {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.oracle-date,
.oracle-card .paper-title__stamp {
  margin: 0 0 6rpx;
  padding: 6rpx 18rpx;
  line-height: 1.25;
}

.oracle-card .paper-title__rail {
  width: 100%;
  margin-top: 8rpx;
}

.oracle-title {
  display: block;
  margin: 0;
  color: var(--page-theme);
  font-size: 44rpx;
  line-height: 1.12;
  font-weight: 900;
  letter-spacing: 0;
}

.oracle-sky {
  z-index: 1;
  top: 8rpx;
  right: 18rpx;
  width: 112rpx;
  height: 112rpx;
  opacity: .16;
}

.oracle-ring {
  position: absolute;
  left: 18rpx;
  top: 20rpx;
  width: 98rpx;
  height: 98rpx;
  border: 3rpx solid rgba(27, 58, 92, .48);
  border-radius: 50%;
  box-shadow: inset 0 0 0 16rpx rgba(184, 138, 74, .08);
}

.oracle-star {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid rgba(184, 138, 74, .9);
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
  background: #fffefb;
}

.star-a { left: 10rpx; top: 18rpx; }
.star-b { right: 20rpx; top: 42rpx; border-color: rgba(184, 74, 58, .75); }
.star-c { left: 56rpx; bottom: 8rpx; border-color: rgba(47, 107, 79, .75); }

.oracle-content {
  margin-top: 18rpx;
}

.oracle-metrics {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
  text-align: left;
}

.oracle-metric {
  position: relative;
  padding: 12rpx 16rpx 12rpx 20rpx;
  border: 2rpx solid rgba(184, 138, 74, .38);
  border-left-width: 8rpx;
  border-radius: 18rpx;
  background: rgba(255, 254, 251, .78);
  box-shadow: 0 8rpx 20rpx rgba(74, 52, 40, .05);
}

.metric-name {
  display: block;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.36;
  font-weight: 900;
}

.metric-desc {
  display: block;
  margin-top: 5rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.oracle-slip-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12rpx;
  margin-top: 16rpx;
  text-align: left;
}

.oracle-slip {
  min-height: 104rpx;
}

.slip-label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.slip-text {
  display: block;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.56;
  font-weight: 900;
}
