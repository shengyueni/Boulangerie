<view class="page paper-page diary-detail-page theme-diary">
  <view class="page-head paper-title detail-title-board title-pattern-card"><image class="title-pattern-image" src="/assets/tabbar-source/dark-green.png" mode="aspectFill" /><view class="title-pattern-mask"></view>
    <view class="corner-ornament corner-ornament-left corner-ornament--blue"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <view class="paper-corner bottom-left"></view>
    <view class="paper-corner bottom-right"></view>
    <text class="paper-title__stamp">记录详情</text>
    <text class="hero-title">判断记录详情</text>
    <text class="subtext">一条记录，就是把一团乱线放到桌面上慢慢看。</text>
    <view class="paper-title__rail"><view class="paper-title__rail-line"></view><view class="paper-title__rail-dot"></view><view class="paper-title__rail-dot"></view><view class="paper-title__rail-line"></view></view>
  </view>

  <view wx:if="{{!entry}}" class="empty-card">
    <text>这条记录可能已经出走了。</text>
    <button class="sticker-button secondary" bindtap="goDiary">回到日记本</button>
  </view>

  <block wx:else>
    <view class="archive-card memo-paper detail-card">
      <view class="corner-ornament corner-ornament-left corner-ornament--gold"></view>
      <view class="corner-ornament corner-ornament-right corner-ornament--blue"></view>
      <view class="paper-corner bottom-right"></view>
      <view class="row between detail-top"><text class="date">{{entry.displayDate}}</text><text class="paper-seal detail-type negative">{{entry.typeLabel}}</text></view>
      <text class="section-title detail-title">事件事实</text>
      <text class="detail-text">{{entry.summary}}</text>
    </view>

    <view class="paper-divider"><view class="paper-divider__line"></view><text class="paper-divider__tag">整理后的线索</text><view class="paper-divider__line"></view></view>

    <view class="archive-card paper-card--record info-card">
      <view class="paper-corner left"></view>
      <view class="paper-corner right"></view>
      <text class="section-title">记录信息</text>
      <view class="info-grid">
        <view class="info-row"><text>影响程度</text><text>{{entry.impactLevel}} 级</text></view>
        <view class="info-row"><text>主要归因</text><text>{{entry.primaryReason}}</text></view>
        <view class="info-row vertical"><text>补充线索</text><text>{{entry.tagsText}}</text></view>
        <view class="info-row vertical"><text>身体反应</text><text>{{entry.bodyReactionsText}}</text></view>
        <view class="info-row vertical"><text>情绪反应</text><text>{{entry.emotionsText}}</text></view>
        <view class="info-row vertical"><text>已尝试处理</text><text>{{entry.triedActionsText}}</text></view>
        <view class="info-row vertical full"><text>更想离开的部分</text><text>{{entry.leaveReasonText}}</text></view>
        <view class="info-row vertical full"><text>想靠近的方向</text><text>{{entry.approachClueText}}</text></view>
        <view class="info-row vertical full"><text>下一步我可以做什么</text><text>{{entry.nextStepText}}</text></view>
      </view>
    </view>

    <view class="paper-divider"><view class="paper-divider__line"></view><text class="paper-divider__tag">可复制证据纸</text><view class="paper-divider__line"></view></view>

    <character-card image="{{companion.image}}" name="{{companion.name}}" tag="{{companion.tag}}" message="{{companion.message}}" sub-message="{{companion.subMessage}}" variant="{{companion.variant}}" size="{{companion.size}}" />

    <view class="archive-card memo-paper evidence-card">
      <view class="corner-ornament corner-ornament-left corner-ornament--red"></view>
      <view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
      <view class="paper-corner bottom-left"></view>
      <view class="paper-corner bottom-right"></view>
      <text class="paper-seal memo-seal">事实纪要</text>
      <text class="section-title">完整事实纪要</text>
      <text class="fact-memo">{{entry.factMemo}}</text>
      <button class="sticker-button copy-seal" bindtap="copyFactMemo">复制事实纪要</button>
    </view>

    <button class="sticker-button secondary" bindtap="goDiary">回到日记本</button>
    <button class="sticker-button green" bindtap="goDashboard">去看决心仪表盘</button>
    <button class="danger-button" bindtap="deleteEntry">删除这条记录</button>
  </block>
</view>
