<view class="page">
  <view class="page-head"><text class="eyebrow">日记详情</text><text class="hero-title">日记详情</text><text class="subtext">一条记录，就是你把自己从混乱里捞出来的一小步。</text></view>
  <view wx:if="{{!entry}}" class="empty-card"><text>这条记录可能已经出走了。</text><button class="sticker-button secondary" bindtap="goDiary">回到日记本</button></view>
  <block wx:else>
    <view class="archive-card detail-card"><view class="row between"><text class="date">{{entry.displayDate}}</text><text class="chip {{entry.type === 'positive' ? 'green' : 'dark'}}">{{entry.typeLabel}}</text></view><text class="section-title detail-title">事件描述</text><text class="detail-text">{{entry.summary}}</text></view>
    <view class="archive-card"><text class="section-title">记录信息</text><view class="info-row"><text>影响等级</text><text>{{entry.impactLevel}}</text></view><view class="info-row"><text>主要原因</text><text>{{entry.primaryReason}}</text></view><view class="info-row vertical"><text>补充标签</text><text>{{entry.tagsText}}</text></view><view class="info-row vertical"><text>身体反应</text><text>{{entry.bodyReactionsText}}</text></view><view class="info-row vertical"><text>情绪</text><text>{{entry.emotionsText}}</text></view><view class="info-row vertical"><text>已尝试处理</text><text>{{entry.triedActionsText}}</text></view><view class="info-row vertical"><text>下一步我可以做什么</text><text>{{entry.nextStepText}}</text></view></view>
    <view class="archive-card memo-card"><text class="section-title">完整事实纪要</text><text class="fact-memo">{{entry.factMemo}}</text><button class="sticker-button green" bindtap="copyFactMemo">复制事实纪要</button></view>
    <button class="sticker-button secondary" bindtap="goDiary">回到日记本</button><button class="sticker-button green" bindtap="goDashboard">去看决心仪表盘</button><button class="danger-button" bindtap="deleteEntry">删除这条记录</button>
  </block>
</view>
