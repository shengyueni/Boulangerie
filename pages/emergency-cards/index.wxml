<view class="page">
  <view class="page-head floral-title-box"><view class="corner-ornament corner-ornament-left corner-ornament--red"></view><view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <text class="eyebrow">护身贴纸</text>
    <text class="hero-title">情绪急救卡片</text>
    <text class="subtext">自责、嫉妒、害怕、无力的时候，先给自己一个温柔但可执行的小回应。</text>
  </view>

  <view wx:if="{{lastAdded}}" class="note-card go-wish-card">
    <text>小动作已经收好。</text>
    <button class="sticker-button secondary" bindtap="goWishlist">去愿望清单看看</button>
  </view>

  <view class="floral-divider"><view class="floral-divider__line"></view><view class="floral-divider__dot red"></view><view class="floral-divider__dot"></view><view class="floral-divider__line"></view></view><view wx:for="{{cards}}" wx:key="title" class="ornament-card ornament-card--red rescue-card {{item.expanded ? 'open' : ''}}" data-index="{{index}}" bindtap="toggleCard">
    <view class="row between">
      <text class="card-title">{{item.title}}</text>
      <text class="toggle-text">{{item.expanded ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{item.expanded}}" class="card-body">
      <text class="label">接住情绪</text>
      <text class="body-text">{{item.hold}}</text>
      <text class="label">重新解释</text>
      <text class="body-text">{{item.reframe}}</text>
      <text class="label">今天可以做的小动作</text>
      <text class="body-text">{{item.action}}</text>
      <button class="sticker-button green" data-index="{{index}}" catchtap="addAction">把这个小动作加入愿望清单</button>
    </view>
  </view>
</view>
