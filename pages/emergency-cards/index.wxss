.rescue-card {
  background: #fffdf6;
}

.rescue-card.open {
  background: #fff2c4;
}

.card-title {
  flex: 1;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.45;
}

.toggle-text {
  color: var(--orange);
  font-size: 24rpx;
  font-weight: 800;
}

.card-body {
  margin-top: 24rpx;
}

.label {
  display: block;
  margin-top: 20rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.body-text {
  display: block;
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.7;
}


.go-wish-card {
  background: #d9efc8;
  font-size: 28rpx;
  line-height: 1.6;
}

.rescue-card { background: #fffefb; }
.rescue-card.open { background: linear-gradient(180deg, #fffefb, #fff8ed); }
.go-wish-card { background: #fffefb; border-color: rgba(47,123,103,.34); }
/* MVP 1.0A emergency cards toolbox theme */
.theme-toolbox .rescue-card.open,
.theme-toolbox .go-wish-card {
  border-color: var(--page-theme-soft);
  background: linear-gradient(180deg, #fffefb, var(--page-tint));
}

.theme-toolbox .toggle-text,
.theme-toolbox .card-title {
  color: var(--page-theme);
}

.emergency-cards-page {
  padding-bottom: calc(82rpx + env(safe-area-inset-bottom));
}

.custom-rescue-section {
  margin-top: 28rpx;
}

.custom-rescue-card,
.custom-rescue-form {
  border-color: var(--page-theme-soft);
  background: linear-gradient(180deg, #fffefb, #fff9ef);
}

.custom-rescue-title {
  display: block;
  color: var(--page-theme);
  font-size: 31rpx;
  line-height: 1.42;
  font-weight: 900;
}

.custom-rescue-content {
  margin-top: 12rpx;
}

.custom-delete-link {
  display: inline-flex;
  min-height: 0;
  margin: 16rpx 0 0;
  padding: 0;
  border: 0;
  color: var(--muted);
  background: transparent;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
  text-decoration: underline;
  box-shadow: none;
}

.custom-delete-link::after {
  border: 0;
}

.custom-rescue-hint {
  margin: 30rpx 8rpx 0;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.6;
  text-align: center;
}

.custom-rescue-form {
  margin-top: 28rpx;
}

.custom-rescue-textarea {
  min-height: 190rpx;
}

.custom-rescue-entry {
  min-height: 88rpx;
  margin-top: 28rpx;
  margin-bottom: env(safe-area-inset-bottom);
  color: var(--page-theme);
  border-color: var(--page-theme-soft);
  background: rgba(255, 254, 251, 0.94);
}
