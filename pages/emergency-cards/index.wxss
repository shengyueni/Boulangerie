.rescue-card {
  background: #fffdf6;
}

.rescue-card.open {
  background: #fff2c4;
}

.card-title {
  flex: 1;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.45;
}

.toggle-text {
  color: var(--orange);
  font-size: 24rpx;
  font-weight: 800;
}

.card-body {
  margin-top: 24rpx;
}

.label {
  display: block;
  margin-top: 20rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.body-text {
  display: block;
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.7;
}


.go-wish-card {
  background: #d9efc8;
  font-size: 28rpx;
  line-height: 1.6;
}

.rescue-card { background: #fffefb; }
.rescue-card.open { background: linear-gradient(180deg, #fffefb, #fff8ed); }
.go-wish-card { background: #fffefb; border-color: rgba(47,123,103,.34); }
/* MVP 1.0A emergency cards toolbox theme */
.theme-toolbox .rescue-card.open,
.theme-toolbox .go-wish-card {
  border-color: var(--page-theme-soft);
  background: linear-gradient(180deg, #fffefb, var(--page-tint));
}

.theme-toolbox .toggle-text,
.theme-toolbox .card-title {
  color: var(--page-theme);
}
