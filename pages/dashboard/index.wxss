.status-card {
  background: #f8c9d2;
}

.status {
  display: block;
  margin: 8rpx 0;
  font-size: 48rpx;
  font-weight: 900;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 24rpx;
}

.stat-card {
  min-height: 156rpx;
  padding: 24rpx;
  border: 3rpx solid var(--border);
  border-radius: 24rpx;
  background: #fffdf6;
  box-shadow: 5rpx 5rpx 0 rgba(63, 52, 45, 0.12);
}

.num {
  display: block;
  margin-bottom: 8rpx;
  color: var(--orange);
  font-size: 50rpx;
  font-weight: 900;
}

.reason {
  font-size: 36rpx;
  font-weight: 800;
}

.reason-row {
  margin-top: 22rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.bar-track {
  height: 20rpx;
  margin-top: 10rpx;
  border: 2rpx solid var(--border);
  border-radius: 999rpx;
  overflow: hidden;
  background: #fffaf0;
}

.bar-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: #f6a6b8;
}

.advice-card {
  background: #fff2c4;
}

.advice {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 800;
}


.trend-empty {
  background: #fff2c4;
}

.dashboard-protect {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx dashed rgba(74, 57, 47, 0.45);
  border-radius: 18rpx;
  background: rgba(255, 253, 246, 0.62);
  font-size: 27rpx;
  line-height: 1.65;
  font-weight: 900;
}

.filter-panel { display: flex; flex-wrap: wrap; margin-top: 18rpx; }
.tendency-card { background: #fff2c4; }
.tendency-title { display: block; margin-bottom: 12rpx; font-size: 36rpx; font-weight: 900; }
.impact-row { margin-top: 18rpx; padding: 18rpx; border: 2rpx dashed rgba(74,57,47,.38); border-radius: 18rpx; background: rgba(255,250,240,.75); }
.impact-date { display: block; color: var(--muted); font-size: 23rpx; font-weight: 800; }
.impact-summary { display: block; margin: 8rpx 0 12rpx; font-size: 28rpx; line-height: 1.5; font-weight: 900; }
.high-empty { margin-top: 12rpx; box-shadow: none; }
.review-card { background: linear-gradient(135deg, #fffdf6, #fff2c4); }

.stats-grid { gap: 16rpx; }
.stat-card { background: #fffefb; border-color: rgba(185,139,75,.36); box-shadow: 0 10rpx 24rpx rgba(78,58,38,.06); }
.tendency-card, .review-card, .advice-card { background: #fffefb; }
.reason-row { padding-top: 8rpx; }
.bar-track { background: #fffaf2; border-color: rgba(185,139,75,.35); }
.bar-fill { background: linear-gradient(90deg, rgba(47,123,103,.5), rgba(185,139,75,.45)); }
.impact-row { background: #fffaf2; border-color: rgba(185,139,75,.36); }
