.filter-panel { display: flex; flex-wrap: wrap; margin-top: 18rpx; }
.range-tags .chip { border-color: rgba(184,138,74,.62); box-shadow: 0 8rpx 18rpx rgba(74,52,40,.06); }

.trend-empty {
  background: rgba(255, 254, 251, 0.88);
}







.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  min-height: 156rpx;
  padding: 24rpx;
  border: 3rpx solid rgba(185,139,75,.36);
  border-radius: 20rpx;
  background: #fffefb;
  box-shadow: 0 10rpx 24rpx rgba(78,58,38,.06);
}

.num {
  display: block;
  margin-bottom: 8rpx;
  color: var(--orange);
  font-size: 50rpx;
  font-weight: 900;
}


.reason-row {
  margin-top: 22rpx;
  padding-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.bar-track {
  height: 20rpx;
  margin-top: 10rpx;
  border: 2rpx solid rgba(185,139,75,.35);
  border-radius: 999rpx;
  overflow: hidden;
  background: #fffaf2;
}

.bar-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: repeating-linear-gradient(90deg, rgba(47,107,79,.72) 0 18rpx, rgba(184,138,74,.72) 18rpx 36rpx);
}

.review-card,
.advice-card {
  background: #fffefb;
}

.review-card {
  padding-top: 42rpx;
}


.advice {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 800;
}


.review-card { background: linear-gradient(135deg, #fffdf6, #fff9ef); }
/* MVP 1.0A dashboard diary theme accents */
.theme-diary .stat-card,
.theme-diary .bar-track {
  border-color: var(--page-theme-soft);
}

.theme-diary .num {
  color: var(--page-theme);
}

.theme-diary .bar-fill {
  background: var(--page-accent);
}
.review-more {
  display: inline-flex;
  margin-top: 16rpx;
  color: var(--page-theme, var(--green));
  font-size: 27rpx;
  line-height: 1.4;
  font-weight: 900;
  text-decoration: underline;
}
