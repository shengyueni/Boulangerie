.filter-panel { display: flex; flex-wrap: wrap; margin-top: 18rpx; }
.range-tags .chip { border-color: rgba(184,138,74,.62); box-shadow: 0 8rpx 18rpx rgba(74,52,40,.06); }

.trend-empty {
  background: rgba(255, 254, 251, 0.88);
}

.croissant-amulet {
  text-align: left;
  background: linear-gradient(180deg, #fffefb, #fff8ed) !important;
}

.croissant-amulet .croissant-status-name {
  margin: 0;
}


.status-explain {
  text-align: left;
}

.dashboard-protect {
  text-align: left;
}

.protect-label {
  color: var(--muted);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-card {
  min-height: 156rpx;
  padding: 24rpx;
  border: 3rpx solid rgba(185,139,75,.36);
  border-radius: 20rpx;
  background: #fffefb;
  box-shadow: 0 10rpx 24rpx rgba(78,58,38,.06);
}

.num {
  display: block;
  margin-bottom: 8rpx;
  color: var(--orange);
  font-size: 50rpx;
  font-weight: 900;
}

.reason {
  font-size: 36rpx;
  font-weight: 800;
}

.reason-row {
  margin-top: 22rpx;
  padding-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.bar-track {
  height: 20rpx;
  margin-top: 10rpx;
  border: 2rpx solid rgba(185,139,75,.35);
  border-radius: 999rpx;
  overflow: hidden;
  background: #fffaf2;
}

.bar-fill {
  height: 100%;
  min-width: 8rpx;
  border-radius: 999rpx;
  background: repeating-linear-gradient(90deg, rgba(47,107,79,.72) 0 18rpx, rgba(184,138,74,.72) 18rpx 36rpx);
}

.tendency-card,
.review-card,
.advice-card {
  background: #fffefb;
}

.tendency-card,
.review-card {
  padding-top: 42rpx;
}

.tendency-title {
  display: block;
  margin-bottom: 12rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.advice {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 800;
}

.impact-row {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx dashed rgba(185,139,75,.36);
  border-left-width: 8rpx;
  border-left-style: solid;
  border-left-color: #B84A3A;
  border-radius: 18rpx;
  background: #fffaf2;
}

.impact-date { display: block; color: var(--muted); font-size: 23rpx; font-weight: 800; }
.impact-summary { display: block; margin: 8rpx 0 12rpx; font-size: 28rpx; line-height: 1.5; font-weight: 900; }
.high-empty { margin-top: 12rpx; box-shadow: none; }
.review-card { background: linear-gradient(135deg, #fffdf6, #fff9ef); }
/* MVP 1.0A dashboard diary theme accents */
.theme-diary .stat-card,
.theme-diary .bar-track,
.theme-diary .impact-row {
  border-color: var(--page-theme-soft);
}

.theme-diary .num,
.theme-diary .tendency-title,
.theme-diary .reason {
  color: var(--page-theme);
}

.theme-diary .bar-fill {
  background: var(--page-accent);
}
