<view class="page paper-page dashboard-page theme-diary">
  <view class="page-head paper-title dashboard-title-board title-pattern-card floral-title-card">
    <image class="title-pattern-image" src="/assets/title-patterns/dark-green.png" mode="aspectFill" />
    <view class="title-pattern-mask"></view>
    <view class="corner-ornament corner-ornament-left corner-ornament--green"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <view class="paper-corner bottom-left"></view>
    <view class="paper-corner bottom-right"></view>
    <view class="title-content">
      <text class="paper-title__stamp">趋势不是审判</text>
      <text class="hero-title">吗喽复盘台</text>
      <text class="subtext">它不会替你决定要不要离职，只帮你看见哪些事正在反复消耗你。</text>
      <view class="paper-title__rail"><view class="paper-title__rail-line"></view><view class="paper-title__rail-dot"></view><view class="paper-title__rail-dot"></view><view class="paper-title__rail-line"></view></view>
    </view>
  </view>

  <character-card image="{{companion.image}}" name="{{companion.name}}" tag="{{companion.tag}}" message="{{companion.message}}" sub-message="{{companion.subMessage}}" variant="{{companion.variant}}" size="{{companion.size}}" />

  <view class="filter-panel range-tags"><view wx:for="{{ranges}}" wx:key="key" class="chip {{activeRange === item.key ? 'pink' : ''}}" data-key="{{item.key}}" bindtap="switchRange">{{item.label}}</view></view>
  <view wx:if="{{!hasRecords}}" class="empty-card trend-empty"><text>还没有足够记录生成趋势。</text><text>先写下一条真实的日记就好。</text></view>

  <view class="ornament-card ornament-card--green advice-card"><view class="corner-ornament corner-ornament-left corner-ornament--green"></view><text class="section-title">当前照顾提示</text><view class="amulet-note"><text class="advice">{{stats.advice}}</text></view></view>
  <view class="stats-grid"><view class="stat-card"><text class="num">{{stats.total}}</text><text>总记录数</text></view><view class="stat-card"><text class="num">{{stats.decisionFactors}}</text><text>日记记录</text></view><view class="stat-card"><text class="num">{{stats.reasonTypes}}</text><text>归因类型</text></view><view class="stat-card"><text class="num">{{stats.highImpact30Days}}</text><text>重要记录</text></view></view>
  <view class="ornament-card"><text class="section-title">主要原因分布</text><view wx:for="{{reasonDistribution}}" wx:key="reason" class="reason-row"><view class="row between"><text>{{item.reason}}</text><text>{{item.count}} 次</text></view><view class="bar-track"><view class="bar-fill" style="width: {{item.percent}}%;"></view></view></view></view>
  <view class="ornament-card ornament-card--gold review-card"><view class="corner-ornament corner-ornament-left corner-ornament--gold"></view><view class="corner-ornament corner-ornament-right corner-ornament--gold"></view><text class="section-title">本周复盘小纸条</text><text class="body-text">{{reviewText}}</text><text class="review-more" bindtap="goDiary">查看更多</text></view>
  <button class="sticker-button secondary" bindtap="goNewDiary">写一条日记</button><button class="sticker-button green" bindtap="goExitTest">去做离职状态自测</button>
</view>
