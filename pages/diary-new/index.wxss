.diary-new-page {
  background: linear-gradient(180deg, #fffefb 0%, #fff9ef 100%);
}

.diary-new-head {
  margin-bottom: 28rpx;
}

.wrap,
.tag-row {
  display: flex;
  flex-wrap: wrap;
}

.record-paper {
  margin-top: 0;
  padding: 42rpx 28rpx 34rpx;
}

.summary-paper {
  margin-top: 24rpx;
}

.record-paper .section-title {
  margin-top: 10rpx;
}

.record-paper .subtext {
  margin: -4rpx 0 18rpx;
  font-size: 25rpx;
}

.record-textarea,
.record-input {
  border-color: rgba(184, 138, 74, 0.38);
  background: rgba(255, 254, 251, 0.9);
  box-shadow: inset 0 0 0 2rpx rgba(255, 248, 237, 0.9);
}

.paper-tag {
  min-height: 44rpx;
}

.save-seal {
  min-height: 92rpx;
  margin-top: 30rpx;
  border: 4rpx double rgba(184, 74, 58, 0.76);
  border-radius: 999rpx;
  color: #B84A3A;
  background: linear-gradient(180deg, #fffefb, #fff2ee);
  box-shadow: 0 12rpx 28rpx rgba(184, 74, 58, 0.14);
  letter-spacing: 1rpx;
}
.record-paper .field-hint {
  margin-top: 12rpx;
}

.record-input {
  margin-bottom: 0;
}
/* MVP 1.0A diary form green theme accents */
.theme-diary .record-textarea,
.theme-diary .record-input,
.theme-diary .record-paper {
  border-color: var(--page-theme-soft);
}

.theme-diary .save-seal {
  color: var(--page-theme);
  border-color: var(--page-theme-soft);
  background: linear-gradient(180deg, #fffefb, var(--page-tint));
}
