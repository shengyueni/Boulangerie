<view class="page paper-page diary-new-page theme-diary">
  <view class="page-head paper-title diary-new-head title-pattern-card"><image class="title-pattern-image" src="/assets/tabbar-source/dark-green.png" mode="aspectFill" /><view class="title-pattern-mask"></view>
    <view class="corner-ornament corner-ornament-left corner-ornament--green"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--green"></view>
    <view class="paper-corner bottom-left"></view>
    <view class="paper-corner bottom-right"></view>
    <text class="paper-title__stamp">离职判断记录纸</text>
    <text class="hero-title">离职判断与归因复盘</text>
    <text class="subtext">不用写得漂亮。先把事实、影响和下一步放到纸片上。</text>
    <view class="paper-title__rail">
      <view class="paper-title__rail-line"></view>
      <view class="paper-title__rail-dot"></view>
      <view class="paper-title__rail-dot"></view>
      <view class="paper-title__rail-line"></view>
    </view>
  </view>

  <character-card image="{{companion.image}}" name="{{companion.name}}" tag="{{companion.tag}}" message="{{companion.message}}" sub-message="{{companion.subMessage}}" variant="{{companion.variant}}" size="{{companion.size}}" />

  <view class="ornament-card paper-card--record record-paper summary-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="paper-seal">第一张纸</text>
    <text class="section-title">发生了什么？</text>
    <textarea class="textarea record-textarea" value="{{summary}}" bindinput="onSummaryInput" placeholder-class="form-placeholder" placeholder="只写事实" />
    <text class="field-hint">谁、什么时候、做了什么、说了什么。先不用急着解释。</text>
  </view>

  <view class="paper-divider"><view class="paper-divider__line"></view><text class="paper-divider__tag">影响与归因</text><view class="paper-divider__line"></view></view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">这件事影响了我什么？</text>
    <view class="tag-row">
      <view wx:for="{{impactLevels}}" wx:key="value" class="paper-tag {{impactLevel === item.value ? 'orange' : ''}}" data-value="{{item.value}}" bindtap="selectImpact">{{item.label}}</view>
    </view>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">它主要碰到了哪一类问题？</text>
    <view class="tag-row">
      <view wx:for="{{reasonOptions}}" wx:key="*this" class="paper-tag {{primaryReason === item ? 'pink' : ''}}" data-reason="{{item}}" bindtap="selectReason">{{item}}</view>
    </view>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">还有哪些线索？</text>
    <text class="subtext">会根据主要归因变化，切换归因时会重新选择。</text>
    <view class="tag-row">
      <view wx:for="{{tagOptions}}" wx:key="label" class="paper-tag {{item.selected ? 'green' : ''}}" data-tag="{{item.label}}" bindtap="toggleTag">{{item.label}}</view>
    </view>
  </view>

  <view class="paper-divider"><view class="paper-divider__line"></view><text class="paper-divider__tag">身体与情绪</text><view class="paper-divider__line"></view></view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">我的身体有什么反应？</text>
    <view class="tag-row">
      <view wx:for="{{bodyReactionOptions}}" wx:key="label" class="paper-tag {{item.selected ? 'orange' : ''}}" data-value="{{item.label}}" bindtap="toggleBodyReaction">{{item.label}}</view>
    </view>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">当时的情绪是什么？</text>
    <view class="tag-row">
      <view wx:for="{{emotionOptions}}" wx:key="label" class="paper-tag {{item.selected ? 'pink' : ''}}" data-value="{{item.label}}" bindtap="toggleEmotion">{{item.label}}</view>
    </view>
  </view>

  <view class="paper-divider"><view class="paper-divider__line"></view><text class="paper-divider__tag">复盘与下一步</text><view class="paper-divider__line"></view></view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">我已经尝试过什么？</text>
    <view class="tag-row">
      <view wx:for="{{triedActionOptions}}" wx:key="label" class="paper-tag {{item.selected ? 'green' : ''}}" data-value="{{item.label}}" bindtap="toggleTriedAction">{{item.label}}</view>
    </view>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">这件事让我更想离开什么？</text>
    <textarea class="textarea record-textarea" value="{{leaveReason}}" bindinput="onLeaveReasonInput" placeholder-class="form-placeholder" placeholder="可选" />
    <text class="field-hint">可以是一种消耗、边界被碰到的方式，或一个反复出现的模式。</text>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">我想靠近什么？</text>
    <textarea class="textarea record-textarea" value="{{approachClue}}" bindinput="onApproachClueInput" placeholder-class="form-placeholder" placeholder="可选" />
    <text class="field-hint">这不是正面打卡，只是一点转向线索：生活、节奏、关系或工作方式。</text>
  </view>

  <view class="ornament-card paper-card--record record-paper">
    <view class="paper-corner left"></view>
    <view class="paper-corner right"></view>
    <text class="section-title">下一步我可以做什么？</text>
    <input class="input record-input" value="{{nextStep}}" bindinput="onNextStepInput" placeholder-class="form-placeholder" placeholder="先记一个小动作" />
    <text class="field-hint">比如：下班后先吃饭，明天整理材料，找朋友聊聊。可以很小，不需要立刻解决人生。</text>
  </view>

  <button class="sticker-button save-seal" bindtap="saveEntry">保存这条记录</button>
</view>
