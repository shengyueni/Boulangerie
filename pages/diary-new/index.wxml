<view class="page">
  <view class="page-head">
    <text class="eyebrow">事实小纸条</text>
    <text class="hero-title">记录今天发生了什么</text>
    <text class="subtext">不用写得漂亮。先把事实、身体和情绪都放到纸片上。</text>
  </view>

  <view class="ornament-card"><text class="section-title">今天发生了什么？</text><textarea class="textarea" value="{{summary}}" bindinput="onSummaryInput" placeholder="写下一个职场事件、一个感受，或者一件让你顺毛的事。" /></view>
  <view class="ornament-card"><text class="section-title">这是一条什么记录？</text><view class="row wrap"><view class="chip {{type === 'negative' ? 'pink' : ''}}" data-type="negative" bindtap="selectType">负面记录</view><view class="chip {{type === 'positive' ? 'green' : ''}}" data-type="positive" bindtap="selectType">正面记录</view></view></view>
  <view class="ornament-card"><text class="section-title">影响等级</text><view wx:for="{{impactLevels}}" wx:key="value" class="chip {{impactLevel === item.value ? 'orange' : ''}}" data-value="{{item.value}}" bindtap="selectImpact">{{item.label}}</view></view>
  <view class="ornament-card"><text class="section-title">主要原因</text><view wx:for="{{reasonOptions}}" wx:key="*this" class="chip {{primaryReason === item ? 'pink' : ''}}" data-reason="{{item}}" bindtap="selectReason">{{item}}</view></view>
  <view class="ornament-card"><text class="section-title">补充标签</text><text class="subtext">会根据主要原因变化，切换原因时会重新选择。</text><view wx:for="{{tagOptions}}" wx:key="label" class="chip {{item.selected ? 'green' : ''}}" data-tag="{{item.label}}" bindtap="toggleTag">{{item.label}}</view></view>
  <view class="ornament-card"><text class="section-title">身体反应</text><view wx:for="{{bodyReactionOptions}}" wx:key="label" class="chip {{item.selected ? 'orange' : ''}}" data-value="{{item.label}}" bindtap="toggleBodyReaction">{{item.label}}</view></view>
  <view class="ornament-card"><text class="section-title">当时的情绪</text><view wx:for="{{emotionOptions}}" wx:key="label" class="chip {{item.selected ? 'pink' : ''}}" data-value="{{item.label}}" bindtap="toggleEmotion">{{item.label}}</view></view>
  <view class="ornament-card"><text class="section-title">已经尝试过什么？</text><view wx:for="{{triedActionOptions}}" wx:key="label" class="chip {{item.selected ? 'green' : ''}}" data-value="{{item.label}}" bindtap="toggleTriedAction">{{item.label}}</view></view>
  <view class="ornament-card"><text class="section-title">下一步我可以做什么？</text><input class="input" value="{{nextStep}}" bindinput="onNextStepInput" placeholder="比如：下班后先吃饭，明天整理证据，找朋友聊聊。" /></view>
  <button class="sticker-button" bindtap="saveEntry">保存这条记录</button>
</view>
