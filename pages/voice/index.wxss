.voice-card {
  background: linear-gradient(135deg, #fffdf6, #fff2c4);
}

.voice-id {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid rgba(74, 57, 47, 0.62);
  border-radius: 999rpx;
  background: #f8c9d2;
  font-size: 23rpx;
  font-weight: 900;
}

.voice-text {
  display: block;
  font-size: 31rpx;
  line-height: 1.65;
  font-weight: 900;
}

.reply-slip {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 2rpx dashed rgba(74, 57, 47, 0.45);
  border-radius: 18rpx;
  background: rgba(255, 253, 246, 0.72);
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.65;
  font-weight: 800;
}

.voice-footer {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
