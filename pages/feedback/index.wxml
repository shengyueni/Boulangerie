<view class="page">
  <view class="page-head">
    <text class="eyebrow">试用小纸条</text>
    <text class="hero-title">试用反馈</text>
    <text class="subtext">先不用写长评。把这 6 个问题复制出去，凭第一感觉回答就很好。</text>
  </view>

  <view class="paper-card">
    <text class="section-title">反馈问题</text>
    <view class="question-list">
      <text wx:for="{{questions}}" wx:key="*this" class="question">{{item}}</text>
    </view>
  </view>

  <button class="sticker-button green" bindtap="copyQuestions">复制反馈问题</button>
  <text class="footer-note">谢谢你愿意帮 Croissant 试走这一步。</text>
</view>
