<view class="page">
  <view class="page-head"><text class="eyebrow">记录已保存</text><text class="hero-title">记录已经放下来了。</text><text class="subtext">{{message}}</text></view>
  <view class="amulet-card"><text class="section-title">事实纪要摘要</text><text class="body-text">{{memoPreview}}</text></view>
  <button class="sticker-button green" bindtap="goDetail">查看这条日记</button>
  <button class="sticker-button secondary" bindtap="goDashboard">去看决心仪表盘</button>
  <button class="sticker-button" bindtap="goBubble">去摇一颗泡泡</button>
  <button class="sticker-button green" bindtap="goPlan">加一个出走计划</button>
</view>
