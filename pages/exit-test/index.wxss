.question-card {
  line-height: 1.6;
}

.question-title {
  display: block;
  font-size: 29rpx;
  font-weight: 800;
}

.score-row {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
}

.score-pill {
  min-height: 92rpx;
  padding: 10rpx 4rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  background: #fff3c7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-weight: 900;
}

.score-pill.active {
  background: #f8c9d2;
}

.score-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 700;
}

.result-card {
  background: #fff2c4;
}

.result-text,
.suggestion {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
}

.small-title {
  margin-top: 24rpx;
  font-size: 30rpx;
}


.score-total {
  display: block;
  margin-bottom: 14rpx;
  color: var(--orange);
  font-size: 42rpx;
  font-weight: 900;
}

.question-card { background: #fffefb; }
.score-pill { background: #fffefb; border-color: rgba(185,139,75,.32); }
.score-pill.active { color: var(--purple); background: #fff8ed; border-color: rgba(76,54,95,.42); }
.result-card { background: linear-gradient(180deg, #fffefb, #fff8ed); }
