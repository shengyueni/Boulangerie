<view class="page">
  <view class="page-head floral-title-box"><view class="corner-ornament corner-ornament-left corner-ornament--purple"></view><view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <text class="eyebrow">温柔问答页</text>
    <text class="hero-title">离职状态自测</text>
    <text class="subtext">它只帮你看见当前状态，不会替你做“必须离职”的绝对结论。</text>
  </view>

  <view wx:for="{{questions}}" wx:for-item="question" wx:for-index="questionIndex" wx:key="title" class="ornament-card ornament-card--purple question-card">
    <text class="question-title">{{questionIndex + 1}}. {{question.title}}</text>
    <view class="score-row">
      <view
        wx:for="{{options}}"
        wx:for-item="option"
        wx:for-index="scoreIndex"
        wx:key="score"
        class="score-pill {{question.selectedScore === option.score ? 'active' : ''}}"
        data-index="{{questionIndex}}"
        data-score="{{option.score}}"
        bindtap="selectScore"
      >
        <text>{{option.score}}</text>
        <text class="score-label">{{option.label}}</text>
      </view>
    </view>
  </view>

  <view class="floral-divider"><view class="floral-divider__line"></view><view class="floral-divider__dot purple"></view><view class="floral-divider__dot"></view><view class="floral-divider__line"></view></view><button class="sticker-button green" bindtap="showResult">查看结果</button>

  <view wx:if="{{result}}" class="amulet-card result-card">
    <text class="score-total">总分：{{totalScore}}</text>
    <text class="section-title">结果类型：{{result.title}}</text>
    <text class="result-text">{{result.text}}</text>
    <text class="section-title small-title">下一步建议</text>
    <view wx:for="{{result.suggestions}}" wx:key="*this" class="suggestion">· {{item}}</view>
    <button class="sticker-button secondary" bindtap="goDiary">去写一条日记</button>
    <button class="sticker-button" bindtap="goWishlist">去愿望清单</button>
    <button class="sticker-button green" bindtap="resetTest">重新测试</button>
  </view>
</view>
