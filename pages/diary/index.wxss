.diary-empty {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.entry-card {
  line-height: 1.6;
}

.entry-card.worn-note {
  border-color: #c96f54;
  background: linear-gradient(135deg, #fffdf6, #fff0e8);
}

.entry-card.worn-note.high-impact {
  border-width: 4rpx;
  box-shadow: 9rpx 9rpx 0 rgba(233, 120, 95, 0.18);
}

.entry-card.smooth-note {
  border-color: #7fb77c;
  background: linear-gradient(135deg, #fffdf6, #eef9e8);
}

.entry-top {
  align-items: flex-start;
}

.date {
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 800;
}

.summary {
  display: block;
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.48;
  font-weight: 900;
}

.meta-chips {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.memo-slip {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 2rpx dashed rgba(74, 57, 47, 0.42);
  border-radius: 18rpx;
  background: rgba(255, 242, 196, 0.7);
}

.memo-label {
  display: block;
  margin-bottom: 8rpx;
  color: var(--muted);
  font-size: 23rpx;
  font-weight: 900;
}

.memo {
  display: block;
  color: #5d4b40;
  font-size: 25rpx;
  line-height: 1.6;
}

.detail-hint {
  display: block;
  margin-top: 14rpx;
  color: var(--orange);
  font-size: 24rpx;
  font-weight: 900;
}

.filter-panel { display: flex; flex-wrap: wrap; margin-top: 22rpx; }
.reason-scroll { width: 100%; margin-top: 8rpx; white-space: nowrap; }
.reason-row-filter { display: inline-flex; padding-bottom: 6rpx; }
