<view class="page">
  <view class="page-head">
    <text class="eyebrow">轻量工具包</text>
    <text class="hero-title">吗喽的百宝箱</text>
    <text class="subtext">先放几件轻量工具：让情绪降一点、让状态清楚一点、让下一步小一点。</text>
  </view>

  <view class="tool-grid">
    <view wx:for="{{items}}" wx:key="title" class="tool-card {{item.color}}" data-index="{{index}}" bindtap="openTool">
      <text class="tool-title">{{item.title}}</text>
      <text class="subtext">{{item.subtitle}}</text>
    </view>
  </view>
</view>
