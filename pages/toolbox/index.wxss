.tool-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; margin-top: 28rpx; }
.tool-card { min-height: 200rpx; margin-top: 0; display: flex; flex-direction: column; justify-content: flex-start; }
.tool-card:nth-child(2n) { margin-top: 18rpx; }
.tool-title { display: block; margin-bottom: 12rpx; font-size: 31rpx; line-height: 1.28; font-weight: 900; }
