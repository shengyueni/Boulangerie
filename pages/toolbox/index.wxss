.drawer-head {
  margin-bottom: 24rpx;
}


.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-items: stretch;
  gap: 18rpx;
  margin-top: 28rpx;
}

.tool-card {
  box-sizing: border-box;
  min-height: 244rpx;
  height: 100%;
  margin-top: 0;
  padding-top: 34rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.tool-title {
  display: block;
  margin: 0 0 12rpx;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 900;
}

.tool-card .subtext {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  font-size: 24rpx;
  line-height: 1.45;
}

.tool-card .corner-ornament {
  width: 32rpx;
  height: 32rpx;
  border-width: 3rpx;
  opacity: .6;
}

.tool-card .paper-corner {
  opacity: .38;
}

.tool-card.pink { border-color: rgba(201, 134, 150, .52); }
.tool-card.green { border-color: rgba(47, 107, 79, .52); }
.tool-card.yellow { border-color: rgba(184, 138, 74, .56); }
.tool-card.plain { border-color: rgba(90, 70, 56, .32); }
.feedback-note {
  display: flex;
  position: relative;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 28rpx;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.6;
  font-weight: 800;
}

.feedback-title {
  color: var(--green);
  font-size: 30rpx;
  font-weight: 900;
}

.theme-toolbox .drawer-head { border-color: rgba(94, 59, 115, .46); }
.theme-toolbox .feedback-title { color: var(--page-theme); border-color: rgba(94, 59, 115, .38); }
/* MVP 1.0A toolbox purple theme accents */
.theme-toolbox .tool-card.pink,
.theme-toolbox .tool-card.green,
.theme-toolbox .tool-card.yellow,
.theme-toolbox .tool-card.plain,
.theme-toolbox .feedback-note {
  border-color: var(--page-theme-soft);
}

.theme-toolbox .tool-title,
.theme-toolbox .feedback-title {
  color: var(--page-theme);
}