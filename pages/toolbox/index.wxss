.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 22rpx;
  margin-top: 28rpx;
}

.tool-card {
  min-height: 190rpx;
  box-sizing: border-box;
  padding: 26rpx;
  border: 3rpx solid var(--border);
  border-radius: 26rpx;
  background: #fffdf6;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 6rpx 6rpx 0 rgba(63, 52, 45, 0.13);
}

.tool-card.green {
  background: #d9efc8;
}

.tool-card.pink {
  background: #f8c9d2;
}

.tool-card.yellow {
  background: #ffe8a8;
}

.tool-title {
  margin-bottom: 18rpx;
  font-size: 31rpx;
  font-weight: 900;
}
