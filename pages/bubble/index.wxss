.bubble-note { color: var(--muted); font-size: 27rpx; line-height: 1.65; }
.bubble-machine { padding-top: 40rpx; background: #fffefb; }
.machine-window { position: relative; height: 260rpx; border: 4rpx double rgba(27,58,92,.62); border-radius: 34rpx; overflow: hidden; background: linear-gradient(180deg, #fffefb, #fff9ef); }
.machine-circle { position: absolute; left: 50%; top: 34rpx; width: 142rpx; height: 142rpx; margin-left: -71rpx; border: 4rpx solid rgba(184,138,74,.7); border-radius: 50%; box-shadow: inset 0 0 0 14rpx rgba(184,138,74,.12); }
.machine-bubble { position: absolute; border: 3rpx solid rgba(74,52,40,.38); border-radius: 50%; background: #fffefb; }
.machine-bubble.b1 { width: 42rpx; height: 42rpx; left: 146rpx; top: 58rpx; border-color: rgba(212,90,76,.58); }
.machine-bubble.b2 { width: 34rpx; height: 34rpx; right: 150rpx; top: 92rpx; border-color: rgba(47,107,79,.55); }
.machine-bubble.b3 { width: 26rpx; height: 26rpx; left: 226rpx; top: 132rpx; border-color: rgba(27,58,92,.55); }
.machine-base { position: absolute; left: 88rpx; right: 88rpx; bottom: 42rpx; height: 28rpx; border-top: 5rpx double rgba(184,138,74,.7); border-bottom: 3rpx solid rgba(184,138,74,.4); }
.machine-label { position: absolute; left: 26rpx; bottom: 20rpx; color: var(--blue); font-size: 22rpx; font-weight: 900; letter-spacing: 1rpx; }
.bubble-card { text-align: center; background: #fffefb; padding-top: 46rpx; }
.bubble-card.care { border-color: rgba(212,90,76,.62); }
.bubble-card.encourage { border-color: rgba(47,107,79,.62); }
.bubble-card.ld { border-color: rgba(90,42,95,.68); background: linear-gradient(180deg, #fffefb, #f7f1f7); }
.bubble-card.popped-card { border-style: double; box-shadow: 0 14rpx 34rpx rgba(90,42,95,.16); }
.bubble-orb { width: 132rpx; height: 132rpx; margin: 0 auto 18rpx; border: 4rpx double rgba(90,70,56,.44); border-radius: 50%; box-shadow: inset 0 0 0 12rpx rgba(255,255,255,.34); opacity: .9; }
.bubble-type { margin-top: 12rpx; }
.bubble-text { display: block; margin-top: 28rpx; font-size: 35rpx; line-height: 1.6; font-weight: 900; }
.popped { display: block; margin-top: 24rpx; padding: 18rpx; border: 3rpx dashed rgba(90,42,95,.58); border-radius: 18rpx; color: var(--purple); font-size: 28rpx; line-height: 1.55; font-weight: 900; background: #fff9ef; }
