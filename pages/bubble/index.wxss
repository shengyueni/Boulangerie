.bubble-page {
  background: linear-gradient(180deg, #fffefb 0%, #fff9ef 100%);
}

.bubble-hero-header {
  margin-bottom: 22rpx;
}

.bubble-note {
  position: relative;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.62;
  font-weight: 800;
}

.bubble-machine-stage {
  position: relative;
  min-height: 560rpx;
  padding: 34rpx 24rpx 42rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 22%, rgba(246, 166, 184, 0.18), transparent 26%),
    radial-gradient(circle at 84% 30%, rgba(156, 207, 154, 0.2), transparent 24%),
    linear-gradient(180deg, #fffefb, #fff7ee);
}

.machine-glow {
  position: absolute;
  left: 50%;
  bottom: 42rpx;
  width: 430rpx;
  height: 220rpx;
  transform: translateX(-50%);
  border-radius: 999rpx;
  background: rgba(246, 166, 184, 0.16);
  filter: blur(2rpx);
}

.bubble-machine-image {
  position: relative;
  z-index: 2;
  display: block;
  width: 72%;
  height: 500rpx;
  margin: 0 auto;
}

.floating-bubble {
  position: absolute;
  z-index: 1;
  box-sizing: border-box;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 30% 24%, rgba(255, 255, 255, 0.92) 0 16rpx, transparent 18rpx),
    rgba(255, 255, 255, 0.36);
  box-shadow: 0 14rpx 30rpx rgba(184, 138, 74, 0.11), inset 0 0 0 2rpx rgba(184, 138, 74, 0.14);
}

.stage-bubble-soothe {
  left: 56rpx;
  top: 96rpx;
  width: 132rpx;
  height: 132rpx;
  background-color: rgba(246, 166, 184, 0.22);
}

.stage-bubble-clarity {
  right: 48rpx;
  top: 52rpx;
  width: 156rpx;
  height: 156rpx;
  background-color: rgba(156, 207, 154, 0.22);
}

.stage-bubble-ld {
  right: 40rpx;
  bottom: 70rpx;
  width: 86rpx;
  height: 86rpx;
  opacity: 0.68;
  background-color: rgba(63, 52, 45, 0.12);
}

.bubble-message-area {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.bubble-card {
  position: relative;
  min-height: 260rpx;
  padding: 34rpx 28rpx 30rpx;
  border: 3rpx solid rgba(184, 138, 74, 0.28);
  border-radius: 42rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 32rpx rgba(90, 42, 95, 0.08);
}

.friend-bubble::before,
.friend-bubble::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.48);
  pointer-events: none;
}

.friend-bubble::before {
  width: 78rpx;
  height: 78rpx;
  right: 24rpx;
  top: 22rpx;
}

.friend-bubble::after {
  width: 28rpx;
  height: 28rpx;
  right: 92rpx;
  top: 74rpx;
}

.soothe-bubble {
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(150deg, rgba(255, 249, 252, 0.98), rgba(255, 238, 244, 0.88));
}

.clarity-bubble {
  background:
    radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.84), transparent 28%),
    linear-gradient(150deg, rgba(251, 255, 248, 0.98), rgba(235, 248, 232, 0.9));
}

.bubble-label {
  position: relative;
  z-index: 1;
  display: inline-flex;
  max-width: 100%;
  padding: 7rpx 16rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.32);
  border-radius: 999rpx;
  color: var(--muted);
  background: rgba(255, 254, 251, 0.84);
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 900;
}

.bubble-copy {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 20rpx;
  color: var(--ink);
  font-size: 29rpx;
  line-height: 1.66;
  font-weight: 800;
}

.ld-noise-card {
  position: relative;
  margin-top: 20rpx;
  padding: 24rpx 22rpx;
  border-color: rgba(63, 52, 45, 0.18);
  background: rgba(255, 254, 251, 0.78);
}

.ld-label {
  display: inline-flex;
  padding: 5rpx 14rpx;
  border-radius: 999rpx;
  color: rgba(63, 52, 45, 0.78);
  background: rgba(63, 52, 45, 0.08);
  font-size: 21rpx;
  line-height: 1.3;
  font-weight: 900;
}

.ld-copy {
  display: block;
  margin-top: 12rpx;
  color: rgba(63, 52, 45, 0.86);
  font-size: 25rpx;
  line-height: 1.56;
  font-weight: 800;
}

.ld-hint {
  display: block;
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.56;
  font-weight: 800;
}

.bubble-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.bubble-actions .sticker-button {
  min-height: 78rpx;
  margin-top: 0;
  padding: 0 12rpx;
  font-size: 24rpx;
}

@media (max-width: 360px) {
  .bubble-machine-stage {
    min-height: 450rpx;
    padding: 28rpx 18rpx 34rpx;
  }

  .bubble-machine-image {
    width: 78%;
    height: 390rpx;
  }

  .stage-bubble-soothe {
    left: 28rpx;
    top: 88rpx;
    width: 96rpx;
    height: 96rpx;
  }

  .stage-bubble-clarity {
    right: 26rpx;
    top: 44rpx;
    width: 112rpx;
    height: 112rpx;
  }

  .bubble-message-area,
  .bubble-actions {
    grid-template-columns: 1fr;
  }

  .bubble-card {
    min-height: auto;
    padding: 30rpx 24rpx 28rpx;
  }

  .bubble-copy {
    font-size: 28rpx;
  }
}
