.bubble-page {
  background: linear-gradient(180deg, #fffefb 0%, #fff9ef 100%);
}

.bubble-head {
  margin-bottom: 22rpx;
}

.bubble-note {
  display: flex;
  position: relative;
  flex-direction: column;
  gap: 12rpx;
  color: var(--ink);
  font-size: 26rpx;
  line-height: 1.62;
  font-weight: 800;
}

.bubble-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.bubble-tags text {
  padding: 6rpx 14rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.38);
  border-radius: 999rpx;
  color: var(--muted);
  background: #fffefb;
  font-size: 22rpx;
  font-weight: 900;
}

.bubble-lab {
  padding: 42rpx 24rpx 26rpx;
  text-align: center;
  background: linear-gradient(180deg, #fffefb, #fff8ed);
}

.main-bubble {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  width: 100%;
  max-width: 520rpx;
  min-height: 390rpx;
  margin: 28rpx auto 8rpx;
  padding: 64rpx 46rpx;
  border: 4rpx double rgba(90, 42, 95, 0.38);
  border-radius: 46% 54% 50% 50% / 52% 45% 55% 48%;
  background:
    radial-gradient(circle at 28% 22%, rgba(255, 255, 255, 0.88) 0 34rpx, transparent 36rpx),
    radial-gradient(circle at 68% 74%, rgba(255, 246, 247, 0.74) 0 58rpx, transparent 60rpx),
    linear-gradient(145deg, rgba(255, 254, 251, 0.96), rgba(247, 241, 247, 0.82));
  box-shadow: inset 0 0 0 18rpx rgba(255, 255, 255, 0.34), 0 16rpx 38rpx rgba(90, 42, 95, 0.09);
  overflow: visible;
}

.main-bubble.is-popped {
  border-style: dashed;
  background: linear-gradient(145deg, rgba(255, 254, 251, 0.96), rgba(255, 248, 237, 0.9));
}

.tiny-bubble {
  position: absolute;
  border: 3rpx solid rgba(184, 138, 74, 0.42);
  border-radius: 50%;
  background: rgba(255, 254, 251, 0.72);
}

.tiny-bubble.b1 { width: 42rpx; height: 42rpx; left: 28rpx; top: 68rpx; border-color: rgba(201, 134, 150, 0.5); }
.tiny-bubble.b2 { width: 28rpx; height: 28rpx; right: 42rpx; top: 92rpx; border-color: rgba(47, 107, 79, 0.46); }
.tiny-bubble.b3 { width: 34rpx; height: 34rpx; right: 86rpx; bottom: 52rpx; border-color: rgba(27, 58, 92, 0.42); }

.bubble-category {
  display: inline-flex;
  padding: 7rpx 18rpx;
  border: 2rpx solid rgba(90, 42, 95, 0.34);
  border-radius: 999rpx;
  color: var(--purple);
  background: rgba(255, 254, 251, 0.86);
  font-size: 23rpx;
  line-height: 1.25;
  font-weight: 900;
}

.bubble-text {
  display: block;
  margin-top: 24rpx;
  color: var(--ink);
  font-size: 35rpx;
  line-height: 1.56;
  font-weight: 900;
}

.empty-bubble-text {
  color: var(--muted);
  font-size: 29rpx;
}

.pop-button {
  min-height: 78rpx;
  margin-top: 22rpx;
}

.result-card {
  padding: 34rpx 24rpx 26rpx;
  border-color: rgba(90, 42, 95, 0.42);
  background: linear-gradient(180deg, #fffefb, #fff9ef);
}

.result-seal {
  margin-bottom: 12rpx;
}

.result-line {
  display: block;
  margin-top: 10rpx;
  color: var(--ink);
  font-size: 27rpx;
  line-height: 1.62;
  font-weight: 800;
}

.result-line.strong {
  color: var(--purple);
  font-size: 30rpx;
  font-weight: 900;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.action-row .sticker-button {
  min-height: 72rpx;
  margin-top: 0;
  padding: 0 12rpx;
  font-size: 24rpx;
}

@media (max-width: 360px) {
  .main-bubble {
    min-height: 330rpx;
    padding: 52rpx 32rpx;
  }

  .bubble-text {
    font-size: 31rpx;
  }

  .action-row {
    grid-template-columns: 1fr;
  }
}
