.bubble-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  background:
    radial-gradient(circle at 20rpx 20rpx, rgba(185, 139, 75, 0.05) 0 2rpx, transparent 3rpx) 0 0 / 58rpx 58rpx,
    linear-gradient(180deg, #fffefb 0%, #fffaf1 54%, #fff6ea 100%);
}

.bubble-header {
  margin-bottom: 16rpx;
  padding-bottom: 20rpx;
}

.bubble-kicker {
  display: inline-flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 18rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.34);
  border-radius: 999rpx;
  color: var(--blue);
  background: rgba(255, 254, 251, 0.9);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.25;
}

.bubble-title {
  display: block;
  color: var(--ink);
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.16;
}

.bubble-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.58;
}

.bubble-stage {
  position: relative;
  display: flex;
  min-height: 430rpx;
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
  padding: 42rpx 22rpx 34rpx;
  overflow: visible;
}

.stage-paper-mark {
  position: absolute;
  width: 76rpx;
  height: 76rpx;
  border-color: rgba(184, 138, 74, 0.24);
  pointer-events: none;
}

.stage-paper-mark-left {
  top: 18rpx;
  left: 2rpx;
  border-top: 2rpx solid rgba(184, 138, 74, 0.24);
  border-left: 2rpx solid rgba(184, 138, 74, 0.18);
  border-radius: 18rpx 0 0 0;
}

.stage-paper-mark-right {
  right: 4rpx;
  bottom: 12rpx;
  border-right: 2rpx solid rgba(184, 138, 74, 0.18);
  border-bottom: 2rpx solid rgba(184, 138, 74, 0.24);
  border-radius: 0 0 18rpx 0;
}

.bubble-empty-hint {
  max-width: 520rpx;
  box-sizing: border-box;
  padding: 18rpx 26rpx;
  border: 2rpx dashed rgba(184, 138, 74, 0.22);
  border-radius: 999rpx;
  color: rgba(139, 122, 110, 0.82);
  background: rgba(255, 254, 251, 0.62);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.46;
  text-align: center;
}

.friend-bubble {
  position: relative;
  width: 86%;
  max-width: 610rpx;
  min-height: 250rpx;
  box-sizing: border-box;
  padding: 34rpx 34rpx 36rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 54rpx 62rpx 58rpx 50rpx;
  overflow: visible;
  box-shadow: 0 18rpx 38rpx rgba(78, 58, 38, 0.09), inset 0 0 0 2rpx rgba(184, 138, 74, 0.12);
  transform-origin: center center;
  animation: bubble-rise 220ms ease-out both;
}

.friend-bubble::before,
.friend-bubble::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.54);
  pointer-events: none;
}

.friend-bubble::before {
  top: 26rpx;
  right: 34rpx;
  width: 72rpx;
  height: 72rpx;
}

.friend-bubble::after {
  top: 92rpx;
  right: 100rpx;
  width: 26rpx;
  height: 26rpx;
}

.friend-bubble.gapchick {
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.9), transparent 28%),
    linear-gradient(145deg, #fffafb 0%, #ffeef4 100%);
  border-color: rgba(246, 166, 184, 0.45);
}

.friend-bubble.elodie {
  background:
    radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.92), transparent 28%),
    linear-gradient(145deg, #fbfff8 0%, #eaf7e6 100%);
  border-color: rgba(156, 207, 154, 0.48);
}

.friend-bubble.is-popping {
  animation: bubble-pop 220ms ease-in forwards;
}

.bubble-shine {
  position: absolute;
  top: 30rpx;
  left: 38rpx;
  width: 92rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.54);
  transform: rotate(-18deg);
  pointer-events: none;
}

.bubble-meta {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.bubble-avatar,
.bubble-avatar-fallback {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  background: rgba(255, 254, 251, 0.76);
  box-shadow: 0 8rpx 18rpx rgba(78, 58, 38, 0.08);
}

.bubble-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  font-size: 16rpx;
  font-weight: 900;
  line-height: 1;
}

.bubble-meta-text {
  display: flex;
  min-width: 0;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
}

.bubble-speaker {
  color: var(--ink);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.28;
}

.bubble-tag {
  max-width: 320rpx;
  box-sizing: border-box;
  padding: 5rpx 14rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.26);
  border-radius: 999rpx;
  color: rgba(74, 52, 40, 0.72);
  background: rgba(255, 254, 251, 0.72);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.25;
}

.bubble-text {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 24rpx;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.7;
  word-break: break-word;
}

.bubble-machine-zone {
  position: relative;
  display: flex;
  min-height: 360rpx;
  box-sizing: border-box;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  margin-top: auto;
  padding: 18rpx 0 4rpx;
  transition: transform 140ms ease;
}

.bubble-machine-zone-active {
  transform: scale(0.985);
}

.machine-soft-shadow {
  position: absolute;
  left: 50%;
  bottom: 64rpx;
  width: 430rpx;
  height: 118rpx;
  border-radius: 999rpx;
  background: rgba(246, 166, 184, 0.16);
  transform: translateX(-50%);
  pointer-events: none;
}

.bubble-machine-image {
  position: relative;
  z-index: 1;
  display: block;
  width: 58vw;
  max-width: 440rpx;
  height: 300rpx;
}

.bubble-machine-tip {
  position: relative;
  z-index: 1;
  display: inline-flex;
  margin-top: 10rpx;
  padding: 8rpx 18rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.28);
  border-radius: 999rpx;
  color: var(--muted);
  background: rgba(255, 254, 251, 0.72);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.25;
}

@keyframes bubble-rise {
  from {
    opacity: 0;
    transform: translateY(22rpx) scale(0.96);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes bubble-pop {
  from {
    opacity: 1;
    transform: scale(1);
  }

  to {
    opacity: 0;
    transform: scale(1.08);
  }
}

@media (max-width: 360px) {
  .bubble-page {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .bubble-title {
    font-size: 42rpx;
  }

  .bubble-stage {
    min-height: 380rpx;
    padding: 30rpx 6rpx 24rpx;
  }

  .friend-bubble {
    width: 94%;
    min-height: 240rpx;
    padding: 30rpx 26rpx 32rpx;
    border-radius: 46rpx;
  }

  .bubble-text {
    font-size: 28rpx;
    line-height: 1.66;
  }

  .bubble-machine-zone {
    min-height: 320rpx;
  }

  .bubble-machine-image {
    width: 64vw;
    max-width: 390rpx;
    height: 260rpx;
  }

  .machine-soft-shadow {
    width: 360rpx;
  }
}
