.bubble-note { color: var(--muted); font-size: 27rpx; line-height: 1.65; }
.bubble-machine { background: #fffefb; }
.machine-window { position: relative; height: 220rpx; border: 2rpx solid rgba(185,139,75,.42); border-radius: 28rpx; overflow: hidden; background: linear-gradient(180deg, #fffefb, #fff8ed); }
.machine-line { position: absolute; left: 32rpx; right: 32rpx; top: 50%; border-top: 2rpx dashed rgba(185,139,75,.3); }
.machine-label { position: absolute; left: 26rpx; bottom: 22rpx; color: var(--blue); font-size: 22rpx; font-weight: 900; letter-spacing: 1rpx; }
.floating-dot { position: absolute; border: 2rpx solid rgba(90,70,56,.35); border-radius: 50%; box-shadow: inset 0 0 0 8rpx rgba(255,255,255,.42); }
.floating-dot.pink { width: 82rpx; height: 82rpx; right: 48rpx; top: 36rpx; background: rgba(201,134,150,.42); }
.floating-dot.green { width: 54rpx; height: 54rpx; left: 68rpx; top: 78rpx; background: rgba(47,123,103,.28); }
.floating-dot.gold { width: 44rpx; height: 44rpx; right: 154rpx; bottom: 42rpx; background: rgba(185,139,75,.28); }
.bubble-card { text-align: center; background: #fffefb; }
.bubble-card.care { border-color: rgba(201,134,150,.45); }
.bubble-card.encourage { border-color: rgba(47,123,103,.42); }
.bubble-card.ld { border-color: rgba(76,54,95,.55); background: linear-gradient(180deg, #fffefb, #f5f0f2); }
.bubble-orb { width: 126rpx; height: 126rpx; margin: 0 auto 18rpx; border: 2rpx solid rgba(90,70,56,.34); border-radius: 50%; box-shadow: inset 0 0 0 12rpx rgba(255,255,255,.32); opacity: .82; }
.bubble-type { margin-top: 12rpx; }
.bubble-text { display: block; margin-top: 28rpx; font-size: 35rpx; line-height: 1.6; font-weight: 900; }
.popped { display: block; margin-top: 24rpx; padding: 18rpx; border: 2rpx dashed rgba(76,54,95,.45); border-radius: 18rpx; color: var(--purple); font-size: 28rpx; line-height: 1.55; font-weight: 900; }
