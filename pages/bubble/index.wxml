<view class="page bubble-page paper-page">
  <view class="page-head floral-title-box bubble-header">
    <view class="corner-ornament corner-ornament-left corner-ornament--blue"></view>
    <view class="corner-ornament corner-ornament-right corner-ornament--gold"></view>
    <text class="bubble-kicker">朋友泡泡站</text>
    <text class="bubble-title">吗喽的泡泡机</text>
    <text class="bubble-subtitle">点一点泡泡机，让朋友吹来一句话。</text>
  </view>

  <view class="bubble-stage">
    <view class="stage-paper-mark stage-paper-mark-left"></view>
    <view class="stage-paper-mark stage-paper-mark-right"></view>

    <block wx:if="{{hasBubble && currentBubble}}">
      <view class="friend-bubble {{currentBubble.type}} {{isPopping ? 'is-popping' : ''}}">
        <view class="bubble-shine"></view>
        <view class="bubble-meta">
          <image wx:if="{{currentBubble.avatar}}" class="bubble-avatar" src="{{currentBubble.avatar}}" mode="aspectFit" />
          <view wx:else class="bubble-avatar-fallback">{{currentBubble.speaker}}</view>
          <view class="bubble-meta-text">
            <text class="bubble-speaker">{{currentBubble.speaker}}</text>
            <text class="bubble-tag">{{currentBubble.tag}}</text>
          </view>
        </view>
        <text class="bubble-text">{{currentBubble.text}}</text>
      </view>
    </block>

    <block wx:else>
      <view class="bubble-empty-hint">点下面的泡泡机，吹出一颗泡泡。</view>
    </block>
  </view>

  <view class="bubble-machine-zone" bindtap="handleBubbleMachineTap" hover-class="bubble-machine-zone-active" hover-stay-time="120">
    <image class="bubble-machine-image" src="{{machineImage}}" mode="aspectFit" />
    <text class="bubble-machine-tip">点我吹泡泡</text>
  </view>
</view>
