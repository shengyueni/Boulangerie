.tabs { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-top: 28rpx; }
.tab { padding: 20rpx; border: 3rpx solid var(--border); border-radius: 22rpx; background: #fffdf6; text-align: center; font-size: 26rpx; font-weight: 800; }
.tab.active { background: #f8c9d2; }
.progress-card { background: linear-gradient(135deg, #fffdf6, #fff2c4); }
.progress-line { display: flex; justify-content: space-between; margin-bottom: 10rpx; font-size: 32rpx; font-weight: 900; }
.category-row { display: flex; flex-wrap: wrap; margin-top: 18rpx; }
.wish-row { display: flex; justify-content: space-between; gap: 16rpx; padding: 22rpx 0; border-bottom: 2rpx dashed rgba(74, 57, 47, 0.25); }
.wish-row:last-child { border-bottom: 0; }
.wish-title { flex: 1; font-size: 28rpx; line-height: 1.5; }
.wish-row.done { opacity: 0.62; background: rgba(156, 207, 154, 0.18); }
.done .wish-title { color: var(--muted); text-decoration: line-through; }
.delete { color: var(--orange); font-size: 25rpx; }

.progress-card { background: linear-gradient(180deg, #fffefb, #fff8ed); }
.tabs { border-top: 2rpx solid rgba(185,139,75,.18); padding-top: 22rpx; }
.tab { background: #fffefb; border-color: rgba(90,70,56,.26); }
.tab.active { color: var(--purple); background: #fff8ed; border-color: rgba(76,54,95,.38); }
.wish-row { background: #fffefb; }

.luggage-head { border-color: rgba(47,107,79,.58); }
.progress-card { padding-top: 48rpx; }
.storage-bag { padding-top: 40rpx; }
.checklist-slip { margin-top: 12rpx; padding: 18rpx; border: 2rpx solid rgba(184,138,74,.34); border-radius: 16rpx; background: #fffefb; }
.wish-row.done .wish-title { text-decoration-color: rgba(47,107,79,.65); text-decoration-thickness: 3rpx; }

.theme-wishlist .luggage-head { border-color: rgba(46, 79, 130, .46); }
.theme-wishlist .tab.active { color: var(--page-theme); background: var(--page-tint); border-color: rgba(46, 79, 130, .38); }
.theme-wishlist .delete { color: var(--page-accent); }
/* MVP 1.0A wishlist blue theme accents */
.theme-wishlist .progress-card,
.theme-wishlist .checklist-slip {
  border-color: var(--page-theme-soft);
}

.theme-wishlist .progress-line,
.theme-wishlist .bar-fill {
  color: var(--page-theme);
}

.theme-wishlist .wish-row.done {
  background: rgba(77, 111, 168, 0.12);
}

.theme-wishlist .wish-row.done .wish-title {
  text-decoration-color: rgba(77, 111, 168, 0.55);
}
