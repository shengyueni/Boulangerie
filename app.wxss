/* MVP 1.0A unified floral title card metrics and theme accents */
.page-hero,
.page-head.title-pattern-card,
.floral-title-card {
  box-sizing: border-box;
  min-height: 260rpx;
  margin: 0 0 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.page-head.title-pattern-card.floral-title-box,
.page-head.title-pattern-card.paper-title,
.floral-title-card {
  border-color: var(--page-theme-soft, rgba(184, 138, 74, 0.58));
}

.page-head.title-pattern-card .title-pattern-image,
.floral-title-card .title-pattern-image {
  opacity: 0.16;
}

.page-head.title-pattern-card .title-pattern-mask,
.floral-title-card .title-pattern-mask {
  background: rgba(255, 250, 242, 0.68);
}

.page-head.title-pattern-card .eyebrow,
.page-head.title-pattern-card .tiny-seal,
.page-head.title-pattern-card .paper-title__stamp,
.page-head.title-pattern-card .bubble-kicker,
.floral-title-card .eyebrow,
.floral-title-card .tiny-seal,
.floral-title-card .paper-title__stamp,
.floral-title-card .bubble-kicker {
  margin: 0 0 14rpx;
  padding: 7rpx 18rpx;
  font-size: 22rpx;
  line-height: 1.25;
}

.page-head.title-pattern-card .hero-title,
.page-head.title-pattern-card .bubble-title,
.floral-title-card .hero-title,
.floral-title-card .bubble-title {
  margin: 0;
  font-size: 40rpx;
  line-height: 1.2;
  letter-spacing: 0;
}

.page-head.title-pattern-card .subtext,
.page-head.title-pattern-card .bubble-subtitle,
.floral-title-card .subtext,
.floral-title-card .bubble-subtitle {
