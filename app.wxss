/* MVP 1.0B shared Croissant status card */
.croissant-status-card {
  padding: 34rpx 28rpx 26rpx;
  text-align: left;
}

.croissant-status-header {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx 14rpx;
}

.croissant-status-label {
  margin: 0;
}

.croissant-status-name {
  flex: 1 1 100%;
  min-width: 0;
  margin: 0;
  color: var(--page-theme, var(--ink));
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
}

.croissant-wear-chip {
  margin: 0;
  padding: 7rpx 16rpx;
  color: var(--page-theme, var(--orange));
  border-color: var(--page-theme-soft, rgba(184, 138, 74, 0.48));
  background: rgba(255, 254, 251, 0.9);
  font-size: 23rpx;
  line-height: 1.25;
}

.croissant-status-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.62;
}

.croissant-advice-panel {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border-color: var(--page-theme-soft, rgba(184, 138, 74, 0.46));
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.94), rgba(255, 249, 239, 0.88));
  font-size: 25rpx;
  line-height: 1.56;
  font-weight: 800;
}

.protect-label {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.croissant-status-stats {
  margin-top: 16rpx;
}

.croissant-status-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.croissant-status-actions .sticker-button,
.croissant-status-actions .quick-pill {
  flex: 1 1 180rpx;
  margin-top: 0;
}

.page-head.title-pattern-card .title-content,
.floral-title-card .title-content {
  width: 100%;
}
