page {
  --bg: #FFF9EF;
  --bg-warm: #fff7ea;
  --paper: #FFFEFB;
  --paper-deep: #fff8ed;
  --ink: #4A3428;
  --muted: #8b7a6e;
  --line: #d8c1a0;
  --line-dark: #5a4638;
  --gold: #B88A4A;
  --blue: #1B3A5C;
  --orange: #B84A3A;
  --pink: #c98696;
  --purple: #5A2A5F;
  --green: #2F6B4F;
  --red: #a13d36;
  --shadow: rgba(78, 58, 38, 0.08);
  --radius: 22rpx;
  --space: 24rpx;
  min-height: 100%;
  color: var(--ink);
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 38rpx 30rpx 64rpx;
  background:
    radial-gradient(circle at 18rpx 18rpx, rgba(185, 139, 75, 0.055) 0 2rpx, transparent 3rpx) 0 0 / 54rpx 54rpx,
    linear-gradient(180deg, #fffefb 0%, #fffaf2 48%, #fff7ea 100%);
}

.page-head {
  position: relative;
  margin-bottom: 26rpx;
  padding: 10rpx 0 24rpx;
}

.page-head::after,
.floral-divider {
  content: "";
  display: block;
  width: 190rpx;
  height: 10rpx;
  margin-top: 18rpx;
  border-top: 2rpx solid var(--line);
  border-bottom: 2rpx solid rgba(185, 139, 75, 0.35);
  background: linear-gradient(90deg, transparent, rgba(185, 139, 75, 0.16), transparent);
}

.hero-title {
  display: block;
  margin-bottom: 12rpx;
  color: var(--ink);
  font-size: 48rpx;
  line-height: 1.16;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.eyebrow,
.tiny-seal {
  display: inline-flex;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 8rpx 18rpx;
  border: 2rpx solid var(--line);
  border-radius: 999rpx;
  background: rgba(255, 254, 251, 0.92);
  color: var(--blue);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.tiny-seal {
  margin: 0 0 10rpx;
  color: var(--red);
  border-color: rgba(161, 61, 54, 0.35);
}

.subtext,
.footer-note,
.version-note {
  display: block;
  color: var(--muted);
  font-size: 27rpx;
  line-height: 1.7;
}

.footer-note,
.version-note {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
}

.body-text {
  display: block;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.72;
}

.card,
.paper-card,
.ornament-card,
.amulet-card,
.sticker-card,
.note-card,
.archive-card {
  position: relative;
  box-sizing: border-box;
  margin-top: var(--space);
  padding: 28rpx;
  border: 2rpx solid rgba(90, 70, 56, 0.34);
  border-radius: var(--radius);
  background: rgba(255, 254, 251, 0.96);
  box-shadow: 0 12rpx 34rpx var(--shadow);
  overflow: hidden;
}

.ornament-card,
.amulet-card,
.archive-card {
  border-color: rgba(185, 139, 75, 0.58);
  box-shadow: 0 14rpx 36rpx rgba(78, 58, 38, 0.1);
}

.ornament-card::before,
.amulet-card::before,
.archive-card::before {
  content: "";
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  height: 16rpx;
  border-top: 2rpx solid rgba(185, 139, 75, 0.38);
  border-left: 2rpx solid rgba(185, 139, 75, 0.2);
  border-right: 2rpx solid rgba(185, 139, 75, 0.2);
  border-radius: 16rpx 16rpx 0 0;
  pointer-events: none;
}

.amulet-card {
  padding: 34rpx 30rpx;
  border-width: 3rpx;
  background: linear-gradient(180deg, #fffefb, #fff8ed);
}

.sticker-card,
.note-card {
  border-style: dashed;
  background: #fffdf8;
}

.archive-card {
  background: linear-gradient(180deg, #fffefb, #fff9ef);
}

.corner-flower {
  position: absolute;
  width: 42rpx;
  height: 42rpx;
  border-top: 3rpx solid var(--gold);
  border-left: 3rpx solid var(--gold);
  border-radius: 12rpx 0 0 0;
  opacity: 0.5;
}

.ribbon-title,
.section-title,
.group-title {
  display: block;
  margin-bottom: 18rpx;
  color: var(--ink);
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
}

.ribbon-title,
.group-title {
  margin-top: 34rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid var(--gold);
}

.chip,
.tag {
  display: inline-flex;
  align-items: center;
  margin: 0 12rpx 12rpx 0;
  padding: 10rpx 18rpx;
  border: 2rpx solid rgba(90, 70, 56, 0.32);
  border-radius: 999rpx;
  color: var(--ink);
  background: #fffefb;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.chip.pink,
.tag.active { color: #7d3f52; border-color: rgba(201, 134, 150, 0.48); background: #fff4f6; }
.chip.green { color: var(--green); border-color: rgba(47, 123, 103, 0.38); background: #f4fbf7; }
.chip.orange { color: var(--orange); border-color: rgba(201, 111, 69, 0.4); background: #fff6ef; }
.chip.dark { color: #fffefb; border-color: var(--purple); background: var(--purple); }

.sticker-button,
.button-primary,
.button-secondary,
.danger-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin-top: 20rpx;
  padding: 0 26rpx;
  border: 2rpx solid rgba(90, 70, 56, 0.45);
  border-radius: 999rpx;
  color: var(--ink);
  background: #fffefb;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(78, 58, 38, 0.08);
}

.sticker-button.green,
.button-primary { color: var(--green); border-color: rgba(47, 123, 103, 0.42); background: #f6fbf7; }
.sticker-button.secondary,
.button-secondary { color: #7d3f52; border-color: rgba(201, 134, 150, 0.42); background: #fff6f7; }
.danger-button { color: #fffefb; border-color: var(--purple); background: #5a2f45; }

.input,
.textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 14rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid rgba(90, 70, 56, 0.28);
  border-radius: 18rpx;
  background: #fffefb;
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
}

.input {
  min-height: 84rpx;
}

.textarea {
  min-height: 220rpx;
}

.form-placeholder {
  color: rgba(139, 122, 110, 0.82);
}

.field-hint {
  display: block;
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.empty,
.empty-card {
  box-sizing: border-box;
  margin-top: var(--space);
  padding: 42rpx 28rpx;
  border: 2rpx dashed rgba(185, 139, 75, 0.48);
  border-radius: var(--radius);
  background: rgba(255, 254, 251, 0.82);
  color: var(--muted);
  line-height: 1.7;
  text-align: center;
}

.row { display: flex; align-items: center; gap: 16rpx; }
.between { justify-content: space-between; }
.muted { color: var(--muted); }

.status-card.status-smooth { border-color: rgba(47, 123, 103, 0.42); }
.status-card.status-ruffled { border-color: rgba(185, 139, 75, 0.58); }
.status-card.status-ball { border-color: rgba(201, 111, 69, 0.56); }
.status-card.status-protect { border-color: rgba(76, 54, 95, 0.62); }
.status-name { display: block; margin: 10rpx 0; font-size: 44rpx; line-height: 1.2; font-weight: 900; }
.status-wear { display: inline-flex; margin-bottom: 18rpx; padding: 8rpx 18rpx; border: 2rpx solid rgba(185, 139, 75, 0.48); border-radius: 999rpx; color: var(--orange); background: #fffefb; font-size: 24rpx; font-weight: 900; }


/* 0.3C.1 visible ornament nodes */
.floral-title-box {
  position: relative;
  padding: 28rpx 30rpx 30rpx;
  border: 3rpx double rgba(184, 138, 74, 0.72);
  border-radius: 30rpx;
  background: linear-gradient(180deg, #fffefb, #fff9ef);
}

.floral-title-box .hero-title {
  margin-bottom: 10rpx;
}

.corner-ornament {
  width: 52rpx;
  height: 52rpx;
  box-sizing: border-box;
  border: 4rpx double #B88A4A;
  border-right: 0;
  border-bottom: 0;
  border-radius: 18rpx 0 0 0;
}

.corner-ornament::after {
  content: "";
  display: block;
  width: 22rpx;
  height: 22rpx;
  margin: 12rpx 0 0 12rpx;
  border: 3rpx solid currentColor;
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
}

.corner-ornament--red { color: #B84A3A; border-color: #B84A3A; }
.corner-ornament--green { color: #2F6B4F; border-color: #2F6B4F; }
.corner-ornament--blue { color: #1B3A5C; border-color: #1B3A5C; }
.corner-ornament--gold { color: #B88A4A; border-color: #B88A4A; }
.corner-ornament--purple { color: #5A2A5F; border-color: #5A2A5F; }

.corner-ornament-left,
.corner-ornament-right,
.corner-ornament-bottom-left,
.corner-ornament-bottom-right {
  position: absolute;
  z-index: 1;
  opacity: 0.82;
  pointer-events: none;
}
.corner-ornament-left { left: 16rpx; top: 16rpx; }
.corner-ornament-right { right: 16rpx; top: 16rpx; transform: rotate(90deg); }
.corner-ornament-bottom-right { right: 16rpx; bottom: 16rpx; transform: rotate(180deg); }
.corner-ornament-bottom-left { left: 16rpx; bottom: 16rpx; transform: rotate(270deg); }

.floral-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  height: 34rpx;
  margin: 20rpx 0;
  border: 0;
  background: transparent;
}
.floral-divider__line {
  width: 116rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(184, 138, 74, 0.8), transparent);
}
.floral-divider__dot {
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid #B88A4A;
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
  background: #fffefb;
}
.floral-divider__dot.red { border-color: #B84A3A; }
.floral-divider__dot.green { border-color: #2F6B4F; }
.floral-divider__dot.blue { border-color: #1B3A5C; }
.floral-divider__dot.purple { border-color: #5A2A5F; }

.ornament-line {
  height: 12rpx;
  margin: 18rpx 0;
  border-top: 3rpx solid rgba(184, 138, 74, 0.66);
  border-bottom: 1rpx solid rgba(184, 138, 74, 0.38);
  background: repeating-linear-gradient(90deg, rgba(184, 138, 74, 0.18) 0 12rpx, transparent 12rpx 24rpx);
}

.seal-flower,
.amulet-frame__seal,
.map-place__seal {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38rpx;
  padding: 6rpx 16rpx;
  border: 2rpx solid rgba(184, 74, 58, 0.62);
  border-radius: 999rpx;
  color: #B84A3A;
  background: #fffefb;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.amulet-frame {
  position: relative;
  border: 4rpx double rgba(184, 138, 74, 0.78) !important;
  border-radius: 34rpx !important;
  background: linear-gradient(180deg, #fffefb, #fff9ef) !important;
  box-shadow: 0 16rpx 42rpx rgba(74, 52, 40, 0.12) !important;
}
.amulet-frame__seal { margin-bottom: 12rpx; }
.amulet-frame__bottom { margin-top: 20rpx; }

.ornament-card--red { border-color: rgba(184, 74, 58, 0.62) !important; }
.ornament-card--green { border-color: rgba(47, 107, 79, 0.58) !important; }
.ornament-card--blue { border-color: rgba(27, 58, 92, 0.58) !important; }
.ornament-card--purple { border-color: rgba(90, 42, 95, 0.58) !important; }
.ornament-card--orange { border-color: rgba(212, 90, 76, 0.58) !important; }
.ornament-card--gold { border-color: rgba(184, 138, 74, 0.68) !important; }

.map-route {
  height: 40rpx;
  margin: 8rpx 56rpx -4rpx;
  border-top: 4rpx dotted rgba(184, 138, 74, 0.58);
  border-radius: 50%;
}
.map-place {
  position: relative;
  border: 3rpx solid rgba(184, 138, 74, 0.58);
  border-radius: 26rpx;
  background: #fffefb;
  box-shadow: 0 12rpx 30rpx rgba(74, 52, 40, 0.1);
}
.map-place::after {
  content: "";
  position: absolute;
  right: 18rpx;
  bottom: 16rpx;
  width: 42rpx;
  height: 12rpx;
  border-top: 3rpx solid rgba(184, 138, 74, 0.58);
  border-bottom: 2rpx solid rgba(184, 138, 74, 0.28);
}
.map-place__title { display: block; margin-top: 12rpx; font-size: 31rpx; font-weight: 900; }
.map-place__desc { display: block; margin-top: 10rpx; color: var(--muted); font-size: 25rpx; line-height: 1.55; }

.paper-edge {
  border-left: 8rpx solid rgba(184, 138, 74, 0.46);
}
.red-mark {
  border-left-color: #B84A3A !important;
  box-shadow: 0 12rpx 30rpx rgba(184, 74, 58, 0.12) !important;
}

/* MVP 0.4 visual identity polish */
.paper-page {
  background:
    radial-gradient(circle at 26rpx 30rpx, rgba(184, 138, 74, 0.07) 0 2rpx, transparent 3rpx) 0 0 / 86rpx 86rpx,
    linear-gradient(180deg, #fffefb 0%, #fffaf1 54%, #fff7ea 100%);
}

.paper-title {
  position: relative;
  padding: 34rpx 32rpx 32rpx;
  border: 4rpx double rgba(184, 138, 74, 0.78);
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 254, 251, 0.98), rgba(255, 249, 239, 0.96));
  box-shadow: 0 14rpx 36rpx rgba(74, 52, 40, 0.08);
}

.paper-title__stamp {
  display: inline-flex;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 8rpx 18rpx;
  border: 2rpx solid rgba(184, 74, 58, 0.58);
  border-radius: 999rpx;
  color: #B84A3A;
  background: #fffefb;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.paper-title__rail,
.paper-card__rail {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  opacity: 0.92;
}

.paper-title__rail-line,
.paper-card__rail-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(184, 138, 74, 0.75), transparent);
}

.paper-title__rail-dot,
.paper-card__rail-dot {
  width: 12rpx;
  height: 12rpx;
  border: 3rpx solid rgba(184, 138, 74, 0.86);
  border-radius: 50% 50% 50% 0;
  transform: rotate(45deg);
  background: #fffefb;
}

.paper-card--record {
  padding-top: 40rpx;
  border-color: rgba(184, 138, 74, 0.58);
  background:
    linear-gradient(90deg, rgba(184, 138, 74, 0.12) 0 8rpx, transparent 8rpx),
    linear-gradient(180deg, #fffefb, #fffaf2);
}

.paper-corner {
  position: absolute;
  width: 34rpx;
  height: 34rpx;
  border-top: 3rpx solid rgba(184, 138, 74, 0.76);
  border-left: 3rpx solid rgba(184, 138, 74, 0.76);
  border-radius: 12rpx 0 0 0;
  opacity: 0.72;
  pointer-events: none;
}

.paper-corner.left { left: 16rpx; top: 16rpx; }
.paper-corner.right { right: 16rpx; top: 16rpx; transform: rotate(90deg); }
.paper-corner.bottom-right { right: 16rpx; bottom: 16rpx; transform: rotate(180deg); }
.paper-corner.bottom-left { left: 16rpx; bottom: 16rpx; transform: rotate(270deg); }

.paper-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin: 24rpx 0;
}

.paper-divider__line {
  width: 118rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(184, 138, 74, 0.78), transparent);
}

.paper-divider__tag {
  padding: 5rpx 14rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.56);
  border-radius: 999rpx;
  color: var(--muted);
  background: #fffefb;
  font-size: 20rpx;
  font-weight: 900;
}

.paper-seal {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 22rpx;
  border: 3rpx double rgba(184, 74, 58, 0.74);
  border-radius: 999rpx;
  color: #B84A3A;
  background: #fffefb;
  font-size: 24rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 18rpx rgba(184, 74, 58, 0.1);
}

.paper-tag {
  display: inline-flex;
  align-items: center;
  margin: 0 12rpx 12rpx 0;
  padding: 10rpx 18rpx;
  border: 2rpx solid rgba(184, 138, 74, 0.48);
  border-radius: 12rpx;
  color: var(--ink);
  background: #fffefb;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
  box-shadow: 0 6rpx 14rpx rgba(74, 52, 40, 0.05);
}

.memo-paper {
  position: relative;
  border: 3rpx solid rgba(90, 70, 56, 0.4);
  border-radius: 20rpx;
  background:
    linear-gradient(180deg, rgba(255, 254, 251, 0.96), rgba(255, 247, 234, 0.96)),
    repeating-linear-gradient(180deg, transparent 0 46rpx, rgba(184, 138, 74, 0.1) 46rpx 48rpx);
  box-shadow: 0 14rpx 30rpx rgba(74, 52, 40, 0.08);
}

.amulet-note {
  padding: 22rpx;
  border: 3rpx double rgba(184, 138, 74, 0.66);
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffefb, #fff8ed);
}

.floral-divider__dot.gold { border-color: #B88A4A; }
.paper-tag.pink { color: #7d3f52; border-color: rgba(201, 134, 150, 0.56); background: #fff4f6; }
.paper-tag.green { color: var(--green); border-color: rgba(47, 123, 103, 0.48); background: #f4fbf7; }
.paper-tag.orange { color: var(--orange); border-color: rgba(201, 111, 69, 0.48); background: #fff6ef; }
.paper-tag.dark { color: #fffefb; border-color: var(--purple); background: var(--purple); }

/* MVP 0.9E page theme accents */
.theme-today { --page-theme: #9B4F2F; --page-accent: #D0623B; --page-tint: #F8E6D8; --page-theme-soft: rgba(155, 79, 47, .34); }
.theme-diary { --page-theme: #275B4A; --page-accent: #3E7C62; --page-tint: #E5F1EA; --page-theme-soft: rgba(39, 91, 74, .34); }
.theme-wishlist { --page-theme: #2E4F82; --page-accent: #4D6FA8; --page-tint: #E7EDF8; --page-theme-soft: rgba(46, 79, 130, .34); }
.theme-voice { --page-theme: #B35663; --page-accent: #D47486; --page-tint: #FCE8EE; --page-theme-soft: rgba(179, 86, 99, .34); }
.theme-toolbox { --page-theme: #5E3B73; --page-accent: #7A5592; --page-tint: #F0E6F5; --page-theme-soft: rgba(94, 59, 115, .34); }
.theme-bubble { --page-theme: #5E3B73; --page-accent: #7A5592; --page-tint: #F0E6F5; --page-theme-soft: rgba(94, 59, 115, .34); }

.theme-today .hero-title,
.theme-diary .hero-title,
.theme-wishlist .hero-title,
.theme-voice .hero-title,
.theme-toolbox .hero-title,
.theme-bubble .bubble-title,
.theme-today .oracle-title,
.theme-diary .section-title,
.theme-wishlist .section-title,
.theme-voice .section-title,
.theme-toolbox .tool-title {
  color: var(--page-theme);
}

.theme-today .eyebrow,
.theme-diary .paper-title__stamp,
.theme-wishlist .eyebrow,
.theme-voice .eyebrow,
.theme-toolbox .eyebrow,
.theme-bubble .bubble-kicker,
.theme-today .paper-title__stamp,
.theme-today .metric-name,
.theme-diary .summary,
.theme-wishlist .progress-line,
.theme-voice .voice-id {
  color: var(--page-theme);
  border-color: var(--page-theme-soft);
}

.theme-today .sticker-button,
.theme-diary .sticker-button,
.theme-wishlist .sticker-button,
.theme-voice .sticker-button,
.theme-toolbox .sticker-button,
.theme-today .quick-pill {
  color: var(--page-theme);
  border-color: var(--page-theme-soft);
}

.theme-today .chip.pink,
.theme-diary .chip.pink,
.theme-wishlist .tab.active,
.theme-voice .tag.active {
  color: var(--page-theme);
  background: var(--page-tint);
  border-color: var(--page-theme-soft);
}

/* MVP 0.9D title-card floral texture layer */
.title-pattern-card {
  position: relative;
  overflow: hidden;
}

.title-pattern-image {
  position: absolute;
  inset: 0;
  z-index: 0;
  width: 100%;
  height: 100%;
  opacity: 0.18;
  pointer-events: none;
}

.title-pattern-mask {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: rgba(255, 250, 242, 0.66);
  pointer-events: none;
}

.title-pattern-card .title-content,
.title-pattern-card .corner-ornament,
.title-pattern-card .paper-corner,
.title-pattern-card .eyebrow,
